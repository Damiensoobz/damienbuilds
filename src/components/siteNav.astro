---
const { home = false, active = "" } = Astro.props;
const p = home ? "" : "/";
const links = [
  { label: "Services", href: `${p}#services` },
  { label: "Work",     href: `${p}#work` },
  { label: "Process",  href: `${p}#process` },
  { label: "Pricing",  href: "/pricing" },
  { label: "FAQ",      href: "/faq" },
  { label: "Contact",  href: `${p}#contact` },
];
---

<nav class="nav" id="mainNav">
  <a class="nav-logo" href="/" aria-label="DamienBuilds home">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 440 56" fill="none" aria-hidden="true">
      <text y="43" x="1" font-family="DM Sans, sans-serif" font-size="43" letter-spacing="-1.7"><tspan font-weight="300" fill="#ffffff">d</tspan><tspan font-weight="700" fill="#ffffff">b</tspan></text>
      <rect x="1" y="47.5" width="50" height="3" rx="1.5" fill="#E96530"/>
      <rect x="70" y="12" width="1" height="30" fill="#ffffff" fill-opacity="0.18" rx="0.5"/>
      <text x="84" y="42" font-family="DM Sans, sans-serif" font-size="34" letter-spacing="-1"><tspan font-weight="300" fill="#ffffff">damien</tspan><tspan font-weight="700" fill="#ffffff">builds</tspan><tspan font-weight="500" fill="#E96530" font-size="14" dy="-3">.dev</tspan></text>
    </svg>
  </a>

  <div class="nav-links">
    {links.map((l) => (
      <a href={l.href} class={active === l.label ? "active" : ""}>{l.label}</a>
    ))}
  </div>

  <button class="hamburger" id="hamburger" aria-label="Toggle menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="mobile-overlay" id="mobileOverlay">
  <nav class="overlay-links">
    {links.map((l) => (
      <a href={l.href} class={`overlay-link ${active === l.label ? "active" : ""}`}>{l.label}</a>
    ))}
  </nav>
</div>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2.5rem;
    background: rgba(12, 21, 37, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(233,101,48,0.12);
    transition: padding 0.3s ease, transform 0.3s ease, background 0.3s ease;
  }

  .nav.hidden { transform: translateY(-100%); }
  .nav.compact { padding: 0.4rem 2.5rem; background: rgba(12, 21, 37, 0.97); }

  .nav-logo {
    position: relative;
    z-index: 101;
    height: 1.5rem;
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .nav-logo svg { height: 100%; width: auto; display: block; }

  .nav-links { display: flex; gap: 1.75rem; }

  .nav-links a {
    color: #ffffff;
    text-decoration: none;
    font-size: 0.88rem;
    letter-spacing: 0.05em;
    opacity: 0.8;
    transition: opacity 0.2s, color 0.2s;
  }

  .nav-links a:hover { opacity: 1; color: #E96530; }
  .nav-links a.active { opacity: 1; color: #E96530; }

  /* ── Hamburger ── */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    position: relative;
    z-index: 101;
  }

  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: #ffffff;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ── Overlay ── */
  .mobile-overlay {
    display: flex;          /* always flex so opacity transition fires */
    position: fixed;
    inset: 0;
    z-index: 98;
    background: rgba(12, 21, 37, 0.98);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    justify-content: center;
    align-items: center;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    /* delay visibility on close so it hides after the fade-out completes */
    transition: opacity 0.3s ease, visibility 0s linear 0.3s;
  }

  .mobile-overlay.open {
    opacity: 1;
    visibility: visible;
    pointer-events: all;
    /* remove visibility delay on open — show immediately, then fade in */
    transition: opacity 0.3s ease, visibility 0s linear 0s;
  }

  .overlay-links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
    padding: 2rem 1.5rem;
  }

  .overlay-link {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.2rem;
    font-weight: 500;
    color: #ffffff;
    text-decoration: none;
    opacity: 0.85;
    letter-spacing: 0.05em;
    transition: opacity 0.2s, color 0.2s;
  }

  .overlay-link:hover { opacity: 1; color: #E96530; }
  .overlay-link.active { color: #E96530; }

  @media (max-width: 820px) {
    .hamburger { display: flex; }
    .nav-links { display: none; }
  }

  @media (max-width: 430px) {
    .nav         { padding: 0.85rem 1.25rem; }
    .nav.compact { padding: 0.4rem 1.25rem; }
    .overlay-link { font-size: 1.85rem; gap: 1.4rem; }
  }
</style>

<script>
  const nav = document.getElementById('mainNav');
  const hamburger = document.getElementById('hamburger');
  const overlay = document.getElementById('mobileOverlay');
  let lastScrollY = window.scrollY;
  let ticking = false;

  hamburger?.addEventListener('click', () => {
    hamburger.classList.toggle('open');
    overlay?.classList.toggle('open');
    document.body.style.overflow =
      overlay?.classList.contains('open') ? 'hidden' : '';
  });

  document.querySelectorAll('.overlay-link').forEach(link => {
    link.addEventListener('click', () => {
      hamburger?.classList.remove('open');
      overlay?.classList.remove('open');
      document.body.style.overflow = '';
    });
  });

  window.addEventListener('scroll', () => {
    if (!ticking) {
      window.requestAnimationFrame(() => {
        const y = window.scrollY;
        if (y <= 10) {
          nav?.classList.remove('hidden', 'compact');
        } else if (y > lastScrollY) {
          nav?.classList.add('hidden');
          nav?.classList.remove('compact');
        } else {
          nav?.classList.remove('hidden');
          nav?.classList.add('compact');
        }
        lastScrollY = y;
        ticking = false;
      });
      ticking = true;
    }
  });
</script>
