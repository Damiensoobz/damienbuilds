---
---

<section class="services" id="services">

  <!-- Contained background cloud image -->
  <div class="services-bg" aria-hidden="true">
    <img src="/images/cloudsbg.jpg" alt="" />
  </div>

  <div class="services-intro">
    <p>Your business deserves to be found.<br/>No cap — pick a package and let's get it done.</p>
  </div>

  <div class="services-body">
    <div class="services-grid">

      <div class="service-card">
        <div class="card-icon">☁️</div>
        <h3>The Starter Pack</h3>
        <p class="card-price">R[TBD]</p>
        <p class="card-desc">Get online before your nephew offers to do it for free and puts Comic Sans everywhere.</p>
        <ul class="card-features">
          <li>5-page website</li>
          <li>Mobile responsive</li>
          <li>Contact form</li>
          <li>Google Business Profile</li>
          <li>Basic SEO</li>
          <li>SSL + hosting setup</li>
        </ul>
        <a href="#contact" class="card-cta">I Need This</a>
      </div>

      <div class="service-card card-featured">
        <div class="card-badge">Most Popular</div>
        <div class="card-icon">🚀</div>
        <h3>Main Character</h3>
        <p class="card-price">R[TBD]</p>
        <p class="card-desc">You showed up. You did the work. Now it's your villain era — in a good way.</p>
        <ul class="card-features">
          <li>Everything in Starter</li>
          <li>Up to 8 pages</li>
          <li>WhatsApp chat button</li>
          <li>Google Analytics</li>
          <li>Gallery section</li>
          <li>Performance optimisation</li>
        </ul>
        <a href="#contact" class="card-cta">Let's Go</a>
      </div>

      <div class="service-card">
        <div class="card-icon">⭐</div>
        <h3>Full Send</h3>
        <p class="card-price">R[TBD]</p>
        <p class="card-desc">Custom design. Premium SEO. You're not here to participate — you're here to win.</p>
        <ul class="card-features">
          <li>Everything in Main Character</li>
          <li>Up to 12 pages</li>
          <li>Custom design</li>
          <li>Advanced local SEO</li>
          <li>Chatbot integration</li>
          <li>1 month support included</li>
        </ul>
        <a href="#contact" class="card-cta">Full Send</a>
      </div>

    </div>

    <div class="pricing-download">
      <p>Want the full breakdown?</p>
      <a href="/downloads/DamienBuilds_Pricing.pdf" download class="download-link">
        Download Pricing Sheet ↓
      </a>
    </div>

  </div>

</section>

<style>
  .services {
    position: relative;
    background: linear-gradient(180deg, #B38782 0%, #D29992 50%, #B38782 100%);
    padding: 7rem 2rem 6rem;
    overflow: hidden;
  }

  /* ── Contained cloud image — sits centered behind everything ── */
  .services-bg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 82%;
    height: 88%;
    z-index: 0;
    overflow: hidden;
  }

  .services-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 10%;
    opacity: 0.75;
  }

  /* ── Intro text box ── */
  .services-intro {
    position: relative;
    z-index: 2;
    width: 55%;
    max-width: 580px;
    margin: 0 auto 4rem;
    background: rgba(240, 236, 228, 0.18);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(240, 236, 228, 0.25);
    padding: 1.25rem 2rem;
    text-align: center;
  }

  .services-intro p {
    font-size: 0.95rem;
    color: #f0ece4;
    line-height: 1.8;
  }

  /* ── Cards body ── */
  .services-body {
    position: relative;
    z-index: 2;
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .service-card {
    position: relative;
    background: rgba(240, 236, 228, 0.12);
    border: 1px solid rgba(240, 236, 228, 0.2);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 2.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    text-align: center;
    transition: transform 0.35s ease, opacity 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
  }

  .service-card:hover {
    transform: scale(1.04);
    border-color: rgba(240, 236, 228, 0.5);
    box-shadow: 0 0 35px rgba(240, 236, 228, 0.1), 0 0 12px rgba(240, 236, 228, 0.06);
  }

  .services-grid:has(.service-card:hover) .service-card:not(:hover) {
    transform: scale(0.96);
    opacity: 0.65;
  }

  .card-featured {
    border-color: #f0ece4;
    background: rgba(240, 236, 228, 0.18);
  }

  .card-badge {
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    background: #f0ece4;
    color: #2c2220;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.25rem 0.85rem;
    white-space: nowrap;
  }

  @keyframes bob {
    0%, 100% { transform: scale(1.45) translateY(0); }
    50%       { transform: scale(1.45) translateY(-7px); }
  }

  .card-icon {
    font-size: 1.75rem;
    margin-bottom: 0.25rem;
    transition: transform 0.2s ease;
    display: inline-block;
  }

  .service-card:hover .card-icon {
    animation: bob 0.75s ease-in-out infinite;
  }

  .service-card h3 {
    font-family: 'Playfair', serif;
    font-size: 1.3rem;
    color: #f0ece4;
    font-weight: 500;
  }

  .card-price {
    font-family: 'Playfair', serif;
    font-size: 1.9rem;
    color: #f0ece4;
    font-weight: 600;
  }

  .card-desc {
    font-size: 0.85rem;
    color: rgba(240, 236, 228, 0.75);
    line-height: 1.6;
  }

  .card-features {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
    width: 100%;
    text-align: left;
  }

  .card-features li {
    font-size: 0.82rem;
    color: rgba(240, 236, 228, 0.85);
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.4;
  }

  .card-features li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #f0ece4;
    font-size: 0.72rem;
  }

  .card-cta {
    display: block;
    width: 100%;
    text-align: center;
    background: transparent;
    border: 1px solid rgba(240, 236, 228, 0.4);
    color: #f0ece4;
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.75rem;
    margin-top: auto;
    transition: background 0.2s, border-color 0.2s;
  }

  .card-cta:hover {
    background: rgba(240, 236, 228, 0.15);
    border-color: #f0ece4;
  }

  .pricing-download {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
  }

  .pricing-download p {
    font-size: 0.85rem;
    color: rgba(240, 236, 228, 0.7);
  }

  .download-link {
    font-size: 0.85rem;
    color: #f0ece4;
    text-decoration: none;
    border-bottom: 1px solid rgba(240, 236, 228, 0.4);
    padding-bottom: 0.1rem;
    transition: opacity 0.2s;
  }

  .download-link:hover {
    opacity: 0.7;
  }

  /* ── Tablet — compact 3-col before collapse ── */
  @media (max-width: 1024px) {
    .services {
      padding: 5rem 1.5rem 5rem;
    }

    .services-body {
      padding: 0 0.5rem;
    }

    .services-grid {
      gap: 1.25rem;
    }

    .service-card {
      padding: 1.75rem 1.1rem;
      gap: 0.6rem;
    }

    .service-card h3 { font-size: 1.1rem; }
    .card-price      { font-size: 1.55rem; }
    .card-desc       { font-size: 0.78rem; }
    .card-features li { font-size: 0.75rem; }
    .card-cta        { font-size: 0.72rem; padding: 0.6rem; }
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .services {
      padding: 5rem 0 4rem; /* no horizontal padding — lets intro center against full viewport */
    }

    /* Hide the section-wide cloud — each card carries its own */
    .services-bg { display: none; }

    .services-intro {
      width: 88%;
      padding: 1rem 1.5rem;
      margin: 0 auto 2.5rem;
      text-align: center;
    }

    .services-body {
      padding: 0 1.25rem; /* horizontal breathing room lives here instead */
    }

    .services-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    /* Per-card blurred cloud background */
    .service-card {
      isolation: isolate;
      overflow: hidden;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      background: rgba(180, 135, 130, 0.25);
    }

    .service-card::after {
      content: '';
      position: absolute;
      inset: -30px;
      background: url('/images/cloudsbg.jpg') center / cover no-repeat;
      filter: blur(18px);
      opacity: 0.7;
      z-index: -1;
    }

    .card-featured {
      background: rgba(180, 135, 130, 0.32);
    }

    .pricing-download {
      flex-direction: column;
      gap: 0.75rem;
      text-align: center;
    }
  }
</style>
