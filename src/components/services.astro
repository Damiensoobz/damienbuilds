---
const services = [
  {
    title: "Web Design & Development",
    desc: "Clean, fast, mobile-first websites built around what your business actually needs. Whether you're running a salon, a panelbeater, or a one-person catering empire out of your kitchen — your site should pull its weight.",
    icon: `<rect x="3" y="4" width="18" height="13" rx="1.5"/><line x1="3" y1="20" x2="21" y2="20"/><line x1="9" y1="20" x2="9" y2="17"/><line x1="15" y1="20" x2="15" y2="17"/>`,
    accent: "#60A5FA",
  },
  {
    title: "Domain & Hosting Setup",
    desc: "I register your domain, set up fast modern hosting (usually free at small-business scale), and wire it all together so your site actually goes live. You won't have to learn what \"DNS propagation\" means. That's my problem, not yours.",
    icon: `<rect x="3" y="4" width="18" height="7" rx="1.5"/><rect x="3" y="13" width="18" height="7" rx="1.5"/><line x1="7" y1="7.5" x2="7" y2="7.5"/><line x1="7" y1="16.5" x2="7" y2="16.5"/>`,
    accent: "#A78BFA",
  },
  {
    title: "Business Email",
    desc: "A proper you@yourbusiness.co.za address through Google Workspace. Because emailing a client from \"durbanplumber94@gmail.com\" quietly costs you the job before you've even quoted.",
    icon: `<rect x="3" y="5" width="18" height="14" rx="1.5"/><polyline points="3,7 12,13 21,7"/>`,
    accent: "#34D399",
  },
  {
    title: "SEO Foundations",
    desc: "Meta tags, Google Business Profile, sitemap submission — the unglamorous groundwork that decides whether you show up when someone searches \"near me\" at 9pm with a burst geyser.",
    icon: `<circle cx="11" cy="11" r="7"/><line x1="16" y1="16" x2="21" y2="21"/>`,
    accent: "#FBBF24",
  },
  {
    title: "Analytics & Tracking",
    desc: "Google Analytics 4, set up and explained. You'll see who's visiting, where they came from, and which page they bailed on — so you're making decisions on facts, not vibes.",
    icon: `<line x1="4" y1="20" x2="4" y2="10"/><line x1="10" y1="20" x2="10" y2="4"/><line x1="16" y1="20" x2="16" y2="13"/><line x1="20" y1="20" x2="20" y2="7"/>`,
    accent: "#F87171",
  },
  {
    title: "WhatsApp Integration",
    desc: "A WhatsApp button wired straight to your number. This is South Africa — your customers don't want a contact form, they want to send you a voice note. Let them.",
    icon: `<path d="M4 20l1.5-4A8 8 0 1 1 9 19.5L4 20Z"/>`,
    accent: "#4ADE80",
  },
];
---

<section class="services" id="services">

  <!-- Video hero band: title + opening text -->
  <div class="services-hero">
    <div class="services-bg" aria-hidden="true">
      <video autoplay muted loop playsinline>
        <source src="/videos/servicesbg.mp4" type="video/mp4" />
      </video>
    </div>
    <div class="services-scrim"></div>
    <div class="services-header">
      <p class="services-label">What I Do</p>
      <h2>Everything you need to get online — and stay there.</h2>
      <p class="services-intro">Most "web guys" build you a pretty page, disappear, and leave you locked out of your own website. I do the opposite. Domain, hosting, email, analytics — I set it all up properly, then hand you the keys with nothing held back. You walk away with a working business, not a digital ornament nobody can find.</p>
    </div>
  </div>

  <!-- Grid subtitle bridge -->
  <div class="services-bridge">
    <p class="bridge-lead">Here's what I work with — your build gets what it actually needs.</p>
  </div>

  <!-- Service grid -->
  <div class="services-inner">
    <div class="services-grid">
      {services.map((s, i) => (
        <div class="service-card" style={`--accent: ${s.accent}`}>
          <span class="service-num">{String(i + 1).padStart(2, '0')}</span>
          <span class="service-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" width="30" height="30" set:html={s.icon}></svg>
          </span>
          <h3>{s.title}</h3>
          <p>{s.desc}</p>
        </div>
      ))}
    </div>
  </div>

</section>

<style>
  .services {
    position: relative;
    background:
      radial-gradient(ellipse 80% 30% at 50% 100%, rgba(233, 101, 48, 0.05) 0%, transparent 100%),
      radial-gradient(ellipse 60% 30% at 100% 0%, rgba(79, 195, 247, 0.04) 0%, transparent 100%),
      #0c1525;
    color: #ffffff;
    padding: 0 0 6rem;
  }

  /* Dot grid texture — same as the hero */
  .services::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255, 255, 255, 0.07) 1px, transparent 1px);
    background-size: 28px 28px;
    z-index: 0;
    pointer-events: none;
  }

  /* ── Video hero band ── */
  .services-hero {
    position: relative;
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 8rem 2rem;
  }

  .services-bg { position: absolute; inset: 0; z-index: 0; }

  .services-bg video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.35;
  }

  .services-scrim {
    position: absolute;
    inset: 0;
    background: rgba(13, 17, 23, 0.72);
    z-index: 1;
  }

  .services-header {
    position: relative;
    z-index: 2;
    max-width: 680px;
    text-align: center;
  }

  .services-label {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #4FC3F7;
    margin-bottom: 0.85rem;
  }

  .services-header h2 {
    font-size: clamp(2.2rem, 4.5vw, 3.6rem);
    font-weight: 400;
    color: #ffffff;
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
    text-shadow: 0 2px 20px rgba(8, 5, 4, 0.5);
  }

  .services-intro {
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.85;
    text-shadow: 0 1px 14px rgba(8, 5, 4, 0.7);
  }

  /* ── Bridge subtitle ── */
  .services-bridge {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 2.5rem 2rem 0;
  }

  .bridge-lead {
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.04em;
  }

  /* ── Grid ── */
  .services-inner {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 4rem auto 0;
    padding: 0 2rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    border-left: 1px solid rgba(255, 255, 255, 0.1);
  }

  .service-card {
    padding: 2.75rem 2rem;
    border-right: 1px solid rgba(255, 255, 255, 0.1);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    gap: 0.85rem;
    transition: background 0.3s ease;
  }

  .service-card:hover {
    background: color-mix(in srgb, var(--accent) 7%, transparent);
  }

  .service-num {
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    color: color-mix(in srgb, var(--accent) 45%, transparent);
    font-family: 'Inter', sans-serif;
    transition: color 0.3s ease;
  }

  .service-icon {
    color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.75rem;
    height: 3.75rem;
    border: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
    border-radius: 50%;
    transition: border-color 0.3s ease, background 0.3s ease, box-shadow 0.3s ease;
    margin-bottom: 0.15rem;
  }

  .service-card:hover .service-icon {
    border-color: color-mix(in srgb, var(--accent) 70%, transparent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    box-shadow: 0 0 16px color-mix(in srgb, var(--accent) 25%, transparent);
  }

  .service-card h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.45rem;
    font-weight: 400;
    color: #ffffff;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .service-card p {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.75;
  }

  /* ── Responsive ── */
  @media (max-width: 880px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
    .services-hero { padding: 6rem 1.5rem; }
  }

  @media (max-width: 560px) {
    .services { padding: 0 0 4rem; }
    .services-hero { padding: 5rem 1.25rem; }
    .services-inner { padding: 0 1.25rem; margin-top: 3rem; }
    .services-grid { grid-template-columns: 1fr; }
    .service-card { padding: 2rem 1.5rem; }
  }

  @media (max-width: 430px) {
    .services-hero  { padding: 4.5rem 1rem; }
    .services-bridge { padding: 1.75rem 1.25rem 0; }
    .services-inner { margin-top: 2rem; padding: 0 1rem; }
    .service-card   { padding: 1.75rem 1.25rem; gap: 0.65rem; }
    .service-card h3 { font-size: 1.3rem; }
  }
</style>
