---
import { FOUNDING_SPOTS_REMAINING, PRICING } from '../data/site';

const included = [
  "Up to 5 pages (Home, About, Services, Contact + 1 of your choice)",
  "Domain registration in your name + all DNS wiring",
  "Hosting set up and your site deployed — login handed to you",
  "Mobile responsive — looks right on every screen, not just yours",
  "On-page SEO basics (meta titles, descriptions, sitemap)",
  "Copy polish — send me messy notes and rough ideas; shaping them into proper website words is part of the job",
  "Contact form",
  "WhatsApp chat button",
  "2 rounds of revisions",
  "SSL setup",
  "Handover document with every login, password, and renewal date",
];

const addOns = [
  {
    label: "Business email setup (Google Workspace)",
    price: "R750",
    info: "A professional you@yourbusiness.co.za inbox, working on your phone before we're done talking. The subscription runs on your card, in your name — I just make it work. Because quoting a client from durbanplumber94@gmail.com quietly costs you jobs you never even hear about.",
  },
  {
    label: "Google Analytics 4 — installation + config",
    price: "R750",
    info: "Analytics installed properly, plus a one-page \"how to read this\" cheat sheet written in human. You'll see how many people visit, where they came from, and which page they bailed on — facts, not vibes.",
  },
  {
    label: "Google Business Profile — setup + optimisation",
    price: "R750",
    info: "Your business on Google Maps and Search, set up and optimised — categories, service areas, photos, the lot. When someone nearby searches what you do at 9pm with a burst geyser, this is what decides whether you exist. You also get a review link to send happy customers, which is how this thing snowballs.",
  },
  {
    label: "Full copywriting",
    price: "R1,500",
    info: "Copy polish is already included — send me anything and I'll shape it. But if you've got nothing at all? I'll interview you, learn the business, and write every word of all five pages myself. You talk, I type.",
  },
  {
    label: "Blog setup + CMS configuration",
    price: "R2,000",
    info: "A blog with a simple editor so you can publish posts yourself — no code, no calling me every time you have something to say. Includes a training session and a written how-to guide. I build it once, teach you once, and then you're independent. That's the point.",
  },
  {
    label: "Site Rescue Audit",
    price: "R850",
    info: "Already have a website that isn't pulling its weight? R850 gets you a straight written verdict: what's broken (speed, mobile, Google visibility, who actually owns your accounts), what fixing it costs, or whether you're honestly better off rebuilding. No sales fog — if a R500 fix solves it, that's what the report will say. And if we do rebuild, the R850 comes off the build price.",
  },
  {
    label: "Additional page (beyond 5)",
    price: "R700/page",
    info: "The standard build covers five pages. Need a menu, a portfolio, or an extra service page? Each one beyond five is a flat R700.",
  },
  {
    label: "Gallery section",
    price: "R600",
    info: "A clean, responsive image gallery to show off your work, your products, or your space — looks sharp on phones too.",
  },
  {
    label: "Extra revision round",
    price: "R500",
    info: "Two rounds of changes come standard. Want another full round after that? R500 per round, no drama.",
  },
];

const carePlan = [
  "Your hosting and domain renewals managed — nothing lapses, nothing expires quietly at 2am",
  "Up to 2 small content changes a month (new prices, updated hours, a swapped photo — the stuff that actually comes up)",
  "Uptime monitoring — if your site goes down, I usually know before you do",
  "A short monthly summary of your traffic, in plain English",
  "Priority WhatsApp support — you skip the queue",
];
---

<section class="pricing" id="pricing">
  <div class="pricing-inner">

    <div class="pricing-header">
      <p class="pricing-label">Pricing</p>
      <h2>Straightforward pricing. The kind you can read in one go.</h2>
      <p class="pricing-sub">One price for the standard build — and it now includes your domain and hosting setup, because a website you can't actually visit isn't a website. Add what you need from the list below; every add-on has a number next to it, because surprise invoices are a crime. Anything bigger gets a custom quote, agreed up front before I touch a thing.</p>
    </div>

    <!-- Running Costs note -->
    <div class="running-costs">
      <p class="rc-label">A note on recurring costs</p>
      <p class="rc-body">What you pay me is once-off. To keep a website live, there are two small yearly costs that belong to you — and I'd rather you hear about them now than when a renewal email lands.</p>
      <ul class="rc-list">
        <li>
          <span class="rc-item-label">Domain (.co.za)</span>
          <span class="rc-item-cost">~R150–R300 / year</span>
          <span class="rc-item-note">Registered in your name, renewed directly through the registrar. It's yours whether you keep working with me or not.</span>
        </li>
        <li>
          <span class="rc-item-label">Hosting</span>
          <span class="rc-item-cost">often R0 / year</span>
          <span class="rc-item-note">Genuinely. Because of how I build (modern static sites, not bloated page-builders), most of my clients' sites run on world-class infrastructure that costs nothing at their size. The R1,200-a-year hosting bill other builders quote you? For a standard build, you usually just don't have one. If your project genuinely needs paid hosting — bookings, a store, heavy traffic — I'll tell you the exact number before we start, and the account will be in your name.</span>
        </li>
      </ul>
      <p class="rc-footnote">I don't mark anything up and I don't hold the accounts. Once it's handed over, the billing — what little there is — is entirely yours.</p>
    </div>

    <!-- Founding offer — slides in above the Standard Build -->
    <div class="founding" id="foundingOffer">
      <div class="badge">⚡ Founding Client Offer</div>
      <div class="founding-grid">
        <div>
          <p class="founding-price">{PRICING.founding}</p>
          <p class="founding-was">down from {PRICING.standard}</p>
        </div>
        <div>
          <p class="founding-desc">Full Standard Build, nothing stripped out — domain and hosting setup included. In exchange I ask for honest feedback and the green light to feature your site as a case study. <strong>First come, first built.</strong></p>
          <p class="founding-note">{FOUNDING_SPOTS_REMAINING} spots remaining.</p>
          <a href="/#contact" class="cta-button">Claim Your Spot →</a>
        </div>
      </div>
    </div>

    <!-- Standard Build panel -->
    <div class="build-hero">
      <p class="build-eyebrow">The Standard Build · Once-off</p>
      <p class="build-price">{PRICING.standard}</p>
      <p class="build-tagline">A complete, professional 5-page website — registered, hosted, live, and ready to be found. One price, on the internet, done.</p>
    </div>

    <!-- What's Included -->
    <div class="block">
      <h3>What's Included</h3>
      <ul class="included-list">
        {included.map((item) => <li>{item}</li>)}
      </ul>
      <div class="own-domain">
        <p class="own-domain-lead">Already own your domain and hosting? <strong>{PRICING.ownDomainDiscount} off.</strong></p>
        <p class="own-domain-note">The discount applies where your existing domain and hosting are accessible and registered in your name. If a previous web guy is holding them hostage, recovering access is quoted separately — and yes, that situation is exactly why I run things the way I do.</p>
      </div>
      <a href="/#contact" class="cta-button">Get Started →</a>
    </div>

    <!-- Add-ons (expandable) -->
    <div class="block block--no-rule">
      <h3>Add-Ons — Fixed Prices, No Asterisks</h3>
      <p class="block-sub">Tap any add-on for a plain-English explainer. Every line has a number — no surprises.</p>
      <div class="addons">
        {addOns.map((item) => (
          <details class="addon">
            <summary>
              <span class="addon-label">{item.label}</span>
              <span class="addon-price">{item.price}</span>
              <span class="addon-icon" aria-hidden="true"></span>
            </summary>
            <div class="addon-body"><p>{item.info}</p></div>
          </details>
        ))}
      </div>
    </div>

    <!-- Care Plan (optional monthly) -->
    <div class="block block--no-rule">
      <div class="care-plan" id="care-plan">
        <p class="care-eyebrow">The Care Plan · {PRICING.carePlanMonthly}/month <span>— optional, cancel anytime</span></p>
        <p class="care-lead">Most of my clients don't need ongoing help — that's the whole point of how I hand things over. But if you'd rather never think about your website again, this is for you.</p>
        <p class="care-list-label">What you get every month</p>
        <ul class="care-list">
          {carePlan.map((item) => <li>{item}</li>)}
        </ul>
        <p class="care-note"><strong>The same rules as everything else apply:</strong> every account stays registered in your name. Cancel anytime, take everything with you, owe me nothing further. A care plan you can't leave isn't care — it's a leash, and I don't sell those.</p>
        <a href="/#contact" class="cta-button cta-button--ghost">Ask About the Care Plan →</a>
      </div>
    </div>

    <!-- Custom -->
    <div class="block">
      <h3>Need Something Bigger?</h3>
      <p class="block-desc">Online stores, booking systems, chatbots, full SEO campaigns — these live outside the standard build because no two are the same. Tell me what you're picturing and I'll come back with a real quote, not an "it depends."</p>
      <a href="/#contact" class="cta-button">Request a Custom Quote →</a>
    </div>

    <!-- Download -->
    <div class="download-row">
      <p>Want it all in one place to mull over with your morning coffee?</p>
      <a href="/downloads/DamienBuilds_Pricing.pdf" download class="download-link">
        Download Pricing Sheet ↓
      </a>
    </div>

  </div>
</section>

<style>
  .pricing {
    background:
      radial-gradient(ellipse 90% 35% at 50% 0%, rgba(79, 195, 247, 0.05) 0%, transparent 100%),
      radial-gradient(ellipse 60% 40% at 0% 100%, rgba(233, 101, 48, 0.04) 0%, transparent 100%),
      linear-gradient(180deg, rgba(0,0,0,0.22) 0%, transparent 8%, transparent 92%, rgba(0,0,0,0.18) 100%),
      #0c1525;
    padding: 7rem 2rem 6rem;
    color: #ffffff;
  }

  .pricing-inner {
    max-width: 820px;
    margin: 0 auto;
  }

  /* ── Header ── */
  .pricing-header { margin-bottom: 3.5rem; }

  .pricing-label {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #4FC3F7;
    margin-bottom: 0.85rem;
  }

  .pricing-header h2 {
    font-size: clamp(2.2rem, 4.5vw, 3.4rem);
    font-weight: 400;
    color: #ffffff;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.1rem;
  }

  .pricing-sub {
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.85;
  }

  /* ── Standard Build panel ── */
  .build-hero {
    background: #112038;
    border: 1px solid rgba(233, 101, 48, 0.22);
    border-top: 2px solid #E96530;
    text-align: center;
    padding: 3rem 2rem;
    margin-bottom: 1rem;
  }

  .build-eyebrow {
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 0.5rem;
  }

  .build-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3rem, 7vw, 4.5rem);
    font-weight: 300;
    color: #E96530;
    line-height: 1;
    margin-bottom: 0.85rem;
    letter-spacing: -0.02em;
  }

  .build-tagline {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.7;
    max-width: 460px;
    margin: 0 auto;
  }

  /* ── Blocks ── */
  .block {
    padding: 2.75rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .block--no-rule { border-bottom: none; }

  .block h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.85rem;
    font-weight: 400;
    color: #ffffff;
    margin-bottom: 1.25rem;
    letter-spacing: -0.01em;
  }

  .block-sub {
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 1.5rem;
    line-height: 1.6;
    margin-top: -0.5rem;
  }

  .block-desc {
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.85;
    margin-bottom: 1.75rem;
  }

  /* ── Included list ── */
  .included-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.85rem 2rem;
  }

  .included-list li {
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.72);
    padding-left: 1.5rem;
    position: relative;
    line-height: 1.55;
  }

  .included-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #E96530;
    font-size: 0.8rem;
    top: 0.05rem;
  }

  /* ── Add-ons accordion ── */
  .addons {
    display: flex;
    flex-direction: column;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .addon {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .addon summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 0.25rem;
    transition: color 0.2s;
  }

  .addon summary::-webkit-details-marker { display: none; }

  .addon-label {
    flex: 1;
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.4;
    transition: color 0.2s;
  }

  .addon summary:hover .addon-label { color: #ffffff; }

  .addon-price {
    font-size: 0.92rem;
    font-weight: 500;
    color: #E96530;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Plus/minus icon */
  .addon-icon {
    position: relative;
    width: 12px;
    height: 12px;
    flex-shrink: 0;
  }

  .addon-icon::before,
  .addon-icon::after {
    content: '';
    position: absolute;
    background: rgba(233, 101, 48, 0.7);
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .addon-icon::before { top: 50%; left: 0; width: 12px; height: 1.5px; transform: translateY(-50%); }
  .addon-icon::after  { left: 50%; top: 0; width: 1.5px; height: 12px; transform: translateX(-50%); }

  .addon[open] .addon-icon::after { opacity: 0; transform: translateX(-50%) rotate(90deg); }

  .addon-body {
    padding: 0 2.5rem 1.25rem 0.25rem;
    overflow: hidden;
  }

  .addon-body p {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.75;
  }

  .addon[open] .addon-body { animation: addonReveal 0.3s ease; }

  @keyframes addonReveal {
    from { opacity: 0; transform: translateY(-5px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── CTA button ── */
  .cta-button {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #0c1525;
    background: #E96530;
    text-decoration: none;
    padding: 0.85rem 2rem;
    transition: background 0.2s, transform 0.2s;
  }

  .cta-button:hover { background: #E96530; transform: translateY(-1px); }

  /* Ghost variant — for secondary / optional CTAs (Care Plan) */
  .cta-button--ghost {
    background: transparent;
    color: #ffffff;
    border: 1px solid rgba(79, 195, 247, 0.4);
  }

  .cta-button--ghost:hover {
    background: rgba(79, 195, 247, 0.08);
    border-color: #4FC3F7;
    color: #4FC3F7;
  }

  /* ── Recurring-costs footnote ── */
  .rc-footnote {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.8;
    margin-top: 1.5rem;
    max-width: 600px;
  }

  /* ── Own-domain discount note ── */
  .own-domain {
    border-left: 2px solid #E96530;
    background: rgba(233, 101, 48, 0.06);
    padding: 1.25rem 1.5rem;
    margin: 0 0 2rem;
  }

  .own-domain-lead {
    font-size: 0.95rem;
    color: #ffffff;
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  .own-domain-lead strong { color: #E96530; font-weight: 600; }

  .own-domain-note {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.7;
    font-style: italic;
  }

  /* ── Care Plan ── */
  .care-plan {
    background: #112038;
    border: 1px solid rgba(79, 195, 247, 0.2);
    border-top: 2px solid #4FC3F7;
    padding: 2.5rem;
  }

  .care-eyebrow {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem;
    font-weight: 500;
    color: #ffffff;
    line-height: 1.2;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }

  .care-eyebrow span {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .care-lead {
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.8;
    margin-bottom: 1.75rem;
  }

  .care-list-label {
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #4FC3F7;
    margin-bottom: 1rem;
  }

  .care-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .care-list li {
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.72);
    padding-left: 1.6rem;
    position: relative;
    line-height: 1.6;
  }

  .care-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    top: 0.05rem;
    color: #4FC3F7;
    font-size: 0.8rem;
  }

  .care-note {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.8;
    margin-bottom: 1.75rem;
  }

  .care-note strong { color: #ffffff; font-weight: 600; }

  /* ── Founding block ── */
  .founding {
    background: rgba(233, 101, 48, 0.08);
    border: 1px solid rgba(233, 101, 48, 0.25);
    padding: 2.5rem;
    margin: 2.75rem 0;
  }

  .badge {
    display: inline-block;
    font-size: 0.62rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #E96530;
    border: 1px solid rgba(233, 101, 48, 0.4);
    padding: 0.3rem 0.7rem;
    margin-bottom: 1.5rem;
  }

  .founding-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  .founding-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3.4rem;
    font-weight: 300;
    color: #E96530;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .founding-was {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.4);
    text-decoration: line-through;
    margin-top: 0.35rem;
  }

  .founding-desc {
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.8;
    margin-bottom: 0.5rem;
  }

  .founding-desc strong { color: #ffffff; font-weight: 600; }

  .founding-note {
    font-size: 0.8rem;
    color: #E96530;
    margin-bottom: 1.5rem;
    letter-spacing: 0.03em;
  }

  /* ── Download row ── */
  .download-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-top: 2.75rem;
    flex-wrap: wrap;
  }

  .download-row p {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.5);
  }

  .download-link {
    font-size: 0.9rem;
    color: #ffffff;
    text-decoration: none;
    border-bottom: 1px solid rgba(233, 101, 48, 0.4);
    padding-bottom: 0.15rem;
    transition: color 0.2s, border-color 0.2s;
    white-space: nowrap;
  }

  .download-link:hover { color: #E96530; border-color: #E96530; }

  /* ── Running Costs ── */
  .running-costs {
    padding: 2.75rem 0;
    margin-bottom: 0;
  }

  .rc-label {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #4FC3F7;
    margin-bottom: 0.85rem;
  }

  .rc-body {
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.85;
    margin-bottom: 1.75rem;
    max-width: 600px;
  }

  .rc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
  }

  .rc-list li {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    column-gap: 2rem;
    padding: 1.1rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }

  .rc-item-label {
    font-size: 0.9rem;
    color: #ffffff;
    font-weight: 500;
    grid-column: 1;
    grid-row: 1;
  }

  .rc-item-cost {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    color: #4FC3F7;
    font-weight: 400;
    grid-column: 2;
    grid-row: 1;
    white-space: nowrap;
    align-self: center;
  }

  .rc-item-note {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.42);
    line-height: 1.6;
    grid-column: 1;
    grid-row: 2;
    padding-top: 0.25rem;
  }

  /* ── Founding offer slide-in ── */
  /* JS adds .will-animate immediately before observing — keeps element visible
     without JS and prevents a blank placeholder flash before the script runs */
  .founding.will-animate {
    opacity: 0;
    transform: translateY(-18px);
    filter: blur(3px);
    transition:
      opacity 0.65s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.65s cubic-bezier(0.16, 1, 0.3, 1),
      filter 0.65s ease;
  }

  .founding.is-visible {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .pricing { padding: 5rem 1.25rem 4rem; }
    .included-list { grid-template-columns: 1fr; }
    .founding { padding: 1.75rem; }
    .founding-grid { grid-template-columns: 1fr; gap: 1.25rem; }
