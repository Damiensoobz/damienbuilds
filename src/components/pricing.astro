---
const included = [
  "Up to 5 pages (Home, About, Services, Contact + 1 of your choice)",
  "Mobile responsive — looks right on every screen, not just yours",
  "On-page SEO basics (meta titles, descriptions, sitemap)",
  "Contact form",
  "WhatsApp chat button",
  "2 rounds of revisions",
  "SSL setup",
  "Handover document with all logins and renewal dates",
];

const addOns = [
  {
    label: "Domain registration + DNS setup",
    price: "R400",
    info: "I register your domain (yourbusiness.co.za) and wire up the technical records so your site loads under it. The domain is registered in your name — you own it, not me.",
  },
  {
    label: "Hosting setup + client handover",
    price: "R500",
    info: "Reliable hosting set up, your site deployed to it, and the login handed straight to you. No renting your own website back through me.",
  },
  {
    label: "Business email setup (Google Workspace)",
    price: "R600",
    info: "A professional you@yourbusiness.co.za inbox through Google Workspace, configured and ready to send and receive on day one.",
  },
  {
    label: "Google Analytics 4 installation + config",
    price: "R800",
    info: "Analytics installed and set up properly, so you can see how many people visit, where they come from, and which pages they actually look at.",
  },
  {
    label: "Google Business Profile setup + optimisation",
    price: "R750",
    info: "Your business added to Google Maps and Search and optimised, so you turn up when someone nearby searches for what you do.",
  },
  {
    label: "Additional page (beyond 5)",
    price: "R700/page",
    info: "The standard build covers five pages. Need a menu, a portfolio, or an extra service page? Each one beyond five is a flat R700.",
  },
  {
    label: "Blog setup + CMS configuration",
    price: "R1,200",
    info: "A blog with a simple editor so you can publish posts yourself — no code, no calling me every time you want to add an article.",
  },
  {
    label: "Gallery section",
    price: "R600",
    info: "A clean, responsive image gallery to show off your work, your products, or your space — looks sharp on phones too.",
  },
  {
    label: "Extra revision round",
    price: "R500",
    info: "Two rounds of changes come standard. Want another full round after that? It's R500 per round, no drama.",
  },
];
---

<section class="pricing" id="pricing">
  <div class="pricing-inner">

    <div class="pricing-header">
      <p class="pricing-label">Pricing</p>
      <h2>Straightforward pricing. The kind you can read in one go.</h2>
      <p class="pricing-sub">One fixed price for the standard build. Add what you need from the list — every add-on has a number next to it, because surprise invoices are a crime. Anything bigger than standard scope gets a custom quote, agreed up front before I touch a thing.</p>
    </div>

    <!-- Running Costs note -->
    <div class="running-costs">
      <p class="rc-label">A note on recurring costs</p>
      <p class="rc-body">What you pay me is once-off. But to keep a website live, you pay two third parties directly each year — and I want you to know about them upfront rather than find out when the renewal email lands. I don't mark these up or hold the accounts. Once I've set everything up and handed it over, the billing is entirely yours.</p>
      <ul class="rc-list">
        <li>
          <span class="rc-item-label">Hosting</span>
          <span class="rc-item-cost">~R600–R1,200 / year</span>
          <span class="rc-item-note">Depends on provider and plan — I'll recommend something reliable that won't quietly double in price after year one.</span>
        </li>
        <li>
          <span class="rc-item-label">Domain (.co.za)</span>
          <span class="rc-item-cost">~R150–R300 / year</span>
          <span class="rc-item-note">Registered in your name, renewed directly through the registrar. It's yours whether you keep working with me or not.</span>
        </li>
      </ul>
    </div>

    <!-- Founding offer — slides in above the Standard Build -->
    <div class="founding" id="foundingOffer">
      <div class="badge">⚡ Founding Client Offer</div>
      <div class="founding-grid">
        <div>
          <p class="founding-price">R4,500</p>
          <p class="founding-was">down from R6,500</p>
        </div>
        <div>
          <p class="founding-desc">Full Standard Build, nothing stripped out. In exchange I ask for honest feedback and the green light to feature your site as a case study. <strong>First come, first built.</strong></p>
          <p class="founding-note">3 spots remaining.</p>
          <a href="#contact" class="cta-button">Claim Your Spot →</a>
        </div>
      </div>
    </div>

    <!-- Standard Build panel -->
    <div class="build-hero">
      <p class="build-eyebrow">The Standard Build · Once-off</p>
      <p class="build-price">R6,500</p>
      <p class="build-tagline">A complete, professional 5-page website. Ready to launch, ready to be found, ready to make you look like you've got your act together.</p>
    </div>

    <!-- What's Included -->
    <div class="block">
      <h3>What's Included</h3>
      <ul class="included-list">
        {included.map((item) => <li>{item}</li>)}
      </ul>
      <a href="#contact" class="cta-button">Get Started →</a>
    </div>

    <!-- Add-ons (expandable) -->
    <div class="block block--no-rule">
      <h3>Add-Ons — Fixed Prices, No Asterisks</h3>
      <p class="block-sub">Tap any add-on for a plain-English explainer. Every line has a number — no surprises.</p>
      <div class="addons">
        {addOns.map((item) => (
          <details class="addon">
            <summary>
              <span class="addon-label">{item.label}</span>
              <span class="addon-price">{item.price}</span>
              <span class="addon-icon" aria-hidden="true"></span>
            </summary>
            <div class="addon-body"><p>{item.info}</p></div>
          </details>
        ))}
      </div>
    </div>

    <!-- Custom -->
    <div class="block">
      <h3>Need Something Bigger?</h3>
      <p class="block-desc">Online stores, booking systems, chatbots, full SEO campaigns — these live outside the standard build because no two are the same. Tell me what you're picturing and I'll come back with a real quote, not an "it depends."</p>
      <a href="#contact" class="cta-button">Request a Custom Quote →</a>
    </div>

    <!-- Download -->
    <div class="download-row">
      <p>Want it all in one place to mull over with your morning coffee?</p>
      <a href="/downloads/DamienBuilds_Pricing.pdf" download class="download-link">
        Download Pricing Sheet ↓
      </a>
    </div>

  </div>
</section>

<style>
  .pricing {
    background:
      radial-gradient(ellipse 90% 35% at 50% 0%, rgba(79, 195, 247, 0.05) 0%, transparent 100%),
      radial-gradient(ellipse 60% 40% at 0% 100%, rgba(233, 101, 48, 0.04) 0%, transparent 100%),
      linear-gradient(180deg, rgba(0,0,0,0.22) 0%, transparent 8%, transparent 92%, rgba(0,0,0,0.18) 100%),
      #0c1525;
    padding: 7rem 2rem 6rem;
    color: #ffffff;
  }

  .pricing-inner {
    max-width: 820px;
    margin: 0 auto;
  }

  /* ── Header ── */
  .pricing-header { margin-bottom: 3.5rem; }

  .pricing-label {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #4FC3F7;
    margin-bottom: 0.85rem;
  }

  .pricing-header h2 {
    font-size: clamp(2.2rem, 4.5vw, 3.4rem);
    font-weight: 400;
    color: #ffffff;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.1rem;
  }

  .pricing-sub {
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.85;
  }

  /* ── Standard Build panel ── */
  .build-hero {
    background: #112038;
    border: 1px solid rgba(233, 101, 48, 0.22);
    border-top: 2px solid #E96530;
    text-align: center;
    padding: 3rem 2rem;
    margin-bottom: 1rem;
  }

  .build-eyebrow {
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 0.5rem;
  }

  .build-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3rem, 7vw, 4.5rem);
    font-weight: 300;
    color: #E96530;
    line-height: 1;
    margin-bottom: 0.85rem;
    letter-spacing: -0.02em;
  }

  .build-tagline {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.7;
    max-width: 460px;
    margin: 0 auto;
  }

  /* ── Blocks ── */
  .block {
    padding: 2.75rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .block--no-rule { border-bottom: none; }

  .block h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.85rem;
    font-weight: 400;
    color: #ffffff;
    margin-bottom: 1.25rem;
    letter-spacing: -0.01em;
  }

  .block-sub {
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 1.5rem;
    line-height: 1.6;
    margin-top: -0.5rem;
  }

  .block-desc {
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.85;
    margin-bottom: 1.75rem;
  }

  /* ── Included list ── */
  .included-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.85rem 2rem;
  }

  .included-list li {
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.72);
    padding-left: 1.5rem;
    position: relative;
    line-height: 1.55;
  }

  .included-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #E96530;
    font-size: 0.8rem;
    top: 0.05rem;
  }

  /* ── Add-ons accordion ── */
  .addons {
    display: flex;
    flex-direction: column;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .addon {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .addon summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 0.25rem;
    transition: color 0.2s;
  }

  .addon summary::-webkit-details-marker { display: none; }

  .addon-label {
    flex: 1;
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.4;
    transition: color 0.2s;
  }

  .addon summary:hover .addon-label { color: #ffffff; }

  .addon-price {
    font-size: 0.92rem;
    font-weight: 500;
    color: #E96530;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Plus/minus icon */
  .addon-icon {
    position: relative;
    width: 12px;
    height: 12px;
    flex-shrink: 0;
  }

  .addon-icon::before,
  .addon-icon::after {
    content: '';
    position: absolute;
    background: rgba(233, 101, 48, 0.7);
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .addon-icon::before { top: 50%; left: 0; width: 12px; height: 1.5px; transform: translateY(-50%); }
  .addon-icon::after  { left: 50%; top: 0; width: 1.5px; height: 12px; transform: translateX(-50%); }

  .addon[open] .addon-icon::after { opacity: 0; transform: translateX(-50%) rotate(90deg); }

  .addon-body {
    padding: 0 2.5rem 1.25rem 0.25rem;
    overflow: hidden;
  }

  .addon-body p {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.75;
  }

  .addon[open] .addon-body { animation: addonReveal 0.3s ease; }

  @keyframes addonReveal {
    from { opacity: 0; transform: translateY(-5px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── CTA button ── */
  .cta-button {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #0c1525;
    background: #E96530;
    text-decoration: none;
    padding: 0.85rem 2rem;
    transition: background 0.2s, transform 0.2s;
  }

  .cta-button:hover { background: #E96530; transform: translateY(-1px); }

  /* ── Founding block ── */
  .founding {
    background: rgba(233, 101, 48, 0.08);
    border: 1px solid rgba(233, 101, 48, 0.25);
    padding: 2.5rem;
    margin: 2.75rem 0;
  }

  .badge {
    display: inline-block;
    font-size: 0.62rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #E96530;
    border: 1px solid rgba(233, 101, 48, 0.4);
    padding: 0.3rem 0.7rem;
    margin-bottom: 1.5rem;
  }

  .founding-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  .founding-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3.4rem;
    font-weight: 300;
    color: #E96530;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .founding-was {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.4);
    text-decoration: line-through;
    margin-top: 0.35rem;
  }

  .founding-desc {
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.8;
    margin-bottom: 0.5rem;
  }

  .founding-desc strong { color: #ffffff; font-weight: 600; }

  .founding-note {
    font-size: 0.8rem;
    color: #E96530;
    margin-bottom: 1.5rem;
    letter-spacing: 0.03em;
  }

  /* ── Download row ── */
  .download-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-top: 2.75rem;
    flex-wrap: wrap;
  }

  .download-row p {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.5);
  }

  .download-link {
    font-size: 0.9rem;
    color: #ffffff;
    text-decoration: none;
    border-bottom: 1px solid rgba(233, 101, 48, 0.4);
    padding-bottom: 0.15rem;
    transition: color 0.2s, border-color 0.2s;
    white-space: nowrap;
  }

  .download-link:hover { color: #E96530; border-color: #E96530; }

  /* ── Running Costs ── */
  .running-costs {
    padding: 2.75rem 0;
    margin-bottom: 0;
  }

  .rc-label {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #4FC3F7;
    margin-bottom: 0.85rem;
  }

  .rc-body {
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.85;
    margin-bottom: 1.75rem;
    max-width: 600px;
  }

  .rc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
  }

  .rc-list li {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    column-gap: 2rem;
    padding: 1.1rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }

  .rc-item-label {
    font-size: 0.9rem;
    color: #ffffff;
    font-weight: 500;
    grid-column: 1;
    grid-row: 1;
  }

  .rc-item-cost {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    color: #4FC3F7;
    font-weight: 400;
    grid-column: 2;
    grid-row: 1;
    white-space: nowrap;
    align-self: center;
  }

  .rc-item-note {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.42);
    line-height: 1.6;
    grid-column: 1;
    grid-row: 2;
    padding-top: 0.25rem;
  }

  /* ── Founding offer slide-in ── */
  /* JS adds .will-animate immediately before observing — keeps element visible
     without JS and prevents a blank placeholder flash before the script runs */
  .founding.will-animate {
    opacity: 0;
    transform: translateY(-18px);
    filter: blur(3px);
    transition:
      opacity 0.65s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.65s cubic-bezier(0.16, 1, 0.3, 1),
      filter 0.65s ease;
  }

  .founding.is-visible {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .pricing { padding: 5rem 1.25rem 4rem; }
    .included-list { grid-template-columns: 1fr; }
    .founding { padding: 1.75rem; }
    .founding-grid { grid-template-columns: 1fr; gap: 1.25rem; }
    .download-row { flex-direction: column; align-items: flex-start; gap: 0.75rem; }
    .addon-body { padding-right: 1.5rem; }
  }

  @media (max-width: 560px) {
    /* Stack cost and price on small screens */
    .rc-list li   { grid-template-columns: 1fr; }
    .rc-item-cost { grid-column: 1; grid-row: 2; padding-top: 0.15rem; font-size: 1rem; }
    .rc-item-note { grid-row: 3; }
  }

  @media (max-width: 430px) {
    .pricing      { padding: 4rem 1rem 3rem; }
    .build-hero   { padding: 2rem 1.25rem; }
    .build-price  { font-size: clamp(2.6rem, 10vw, 3.5rem); }
    .block        { padding: 2rem 0; }
    .founding     { padding: 1.25rem 1rem; }
    .cta-button   { width: 100%; text-align: center; }
    .addon summary { padding: 1rem 0.25rem; }
  }
</style>

<script>
  const founding = document.getElementById('foundingOffer');
  if (founding) {
    // Hide it NOW (before first paint commit) so there's no flash of content before observe
    founding.classList.add('will-animate');
    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            obs.unobserve(e.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    obs.observe(founding);
  }
</script>
