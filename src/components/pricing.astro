<script>
  const founding = document.getElementById('foundingOffer');
  if (founding) {
    // Hide it NOW (before first paint commit) so there's no flash of content before observe
    founding.classList.add('will-animate');
    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            obs.unobserve(e.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    obs.observe(founding);
  }
</script>
