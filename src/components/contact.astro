---
import { PRICING, WEB3FORMS_ACCESS_KEY } from '../data/site';

// Only socials with real URLs render. Facebook is parked below until the
// account is recovered — move it back into the array with the real URL.
const socials = [
  { name: "LinkedIn",    handle: "Damien Subramanian", cls: "social-linkedin", href: "https://www.linkedin.com/in/damien-subramanian-440309194/",
    path: `<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>` },
  { name: "Instagram",   handle: "@damienbuilds.dev", cls: "social-instagram", href: "https://www.instagram.com/damienbuilds.dev/",
    path: `<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>` },
  { name: "GitHub",      handle: "@damiensoobz", cls: "social-github", href: "https://damiensoobz.github.io/projects/",
    path: `<path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>` },
];

/* Parked until the Facebook account is recovered:
  { name: "Facebook",    handle: "damienbuilds.dev", cls: "social-facebook", href: "FACEBOOK_URL_HERE",
    path: `<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>` },
*/
---

<section class="contact-section" id="contact">

  <!-- ── Contact ── -->
  <div class="contact-head">
    <p class="eyebrow">Get In Touch</p>
    <h2>Let's talk about your website.</h2>
    <p class="contact-sub">Fill in the form and I'll get back to you within 24 hours — usually much sooner. No sales pitch, no pressure. Just a straight conversation.</p>
  </div>

  <!-- Form (full width) -->
  <div class="form-wrap">
    <div class="form-box">
      <form class="contact-form" id="contactForm">
        <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
        <input type="hidden" name="subject" value="📨 New enquiry from damienbuilds.dev" />
        <input type="hidden" name="from_name" value="DamienBuilds Website" />
        <!-- Web3Forms honeypot -->
        <input type="checkbox" name="botcheck" class="contact-hp" tabindex="-1" autocomplete="off" />

        <div class="form-row">
          <div class="form-field">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" placeholder="Your name" required />
          </div>
          <div class="form-field">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="your@email.com" required />
          </div>
        </div>

        <div class="form-row">
          <div class="form-field">
            <label for="phone">Phone (optional)</label>
            <input type="tel" id="phone" name="phone" placeholder="+27 00 000 0000" />
          </div>
          <div class="form-field">
            <label for="package">Interested in</label>
            <select id="package" name="package">
              <option value="">Select an option</option>
              <option value="standard">Standard Build — {PRICING.standard}</option>
              <option value="founding">Founding Client Spot — {PRICING.founding}</option>
              <option value="rescue">Site Rescue Audit — {PRICING.siteRescueAudit}</option>
              <option value="care">Care Plan — {PRICING.carePlanMonthly}/month</option>
              <option value="custom">Custom Quote</option>
              <option value="unsure">Not sure yet</option>
            </select>
          </div>
        </div>

        <div class="form-field">
          <label for="message">Tell me about your business</label>
          <textarea id="message" name="message" rows="4" placeholder="What you do, who you're trying to reach, and what's missing right now..." required></textarea>
        </div>

        <button type="submit" class="form-submit" id="contactSubmit">Send It →</button>
        <p class="form-error" id="contactError" hidden></p>
      </form>

      <div class="form-success" id="contactSuccess" hidden>
        <p class="form-success-tick">✓</p>
        <h3>Message sent — thank you.</h3>
        <p>Got it. I'll get back to you within 24 hours, usually sooner. In the meantime, feel free to keep looking around.</p>
      </div>

      <p class="whatsapp-line">Rather just talk? <a href="https://wa.me/27000000000" target="_blank" rel="noopener noreferrer">WhatsApp me directly →</a> Voice notes welcome.</p>
    </div>
  </div>

  <!-- ── About + Socials ── -->
  <div class="about">
    <div class="about-portrait">
      <img src="/images/portrait.jpg" alt="Damien" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
      <div class="portrait-placeholder"><span>Your Photo</span></div>
    </div>
    <div class="about-text">
      <p class="eyebrow">About</p>
      <h2>Hi, I'm Damien.</h2>
      <p>I'm a Durban-based web designer who works in IT for a living — I've spent years being the person people call when tech breaks and the explanation needs to make sense to a human. That's good news for you twice over: the technical stuff gets done properly, and I'm not going anywhere. Tech is my career, not a side experiment.</p>
      <p>I'm not an agency. No account manager you'll never meet, no junior quietly doing the real work. You work with me, start to finish — first chat to final handover. And the IT background means the boring-but-critical stuff (domain, hosting, email, analytics) gets set up properly, not bolted on and forgotten.</p>
      <p>When I hand it over, you actually own it — no strings, no monthly "maintenance" bill that never ends. Based in Phoenix, Durban — working with businesses across South Africa, and open to the rest of the world while I'm at it.</p>
      <div class="about-links">
        <a href="mailto:damien@damienbuilds.dev" class="about-link"><span>✉</span> damien@damienbuilds.dev</a>
        <a href="https://wa.me/27000000000" target="_blank" rel="noopener noreferrer" class="about-link"><span>💬</span> WhatsApp</a>
        <a href="https://damiensoobz.github.io/projects/" target="_blank" rel="noopener noreferrer" class="about-link"><span>💻</span> Personal Projects</a>
        <span class="about-link no-link"><span>📍</span> Phoenix, Durban</span>
      </div>
    </div>

    <!-- Socials — beside the about block -->
    <aside class="socials">
      <p class="eyebrow">Find Me Online</p>
      <div class="socials-list">
        {socials.map((s) => (
          <a href={s.href} target="_blank" rel="noopener noreferrer" class={`social-card ${s.cls}`}>
            <span class="social-icon">
              <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14" set:html={s.path}></svg>
            </span>
            <div>
              <p class="social-name">{s.name}</p>
              <p class="social-handle">{s.handle}</p>
            </div>
          </a>
        ))}
      </div>
    </aside>
  </div>

</section>

<style>
  .contact-section {
    background: #0c1525;
    padding: 7rem 2rem 6rem;
  }

  .eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #4FC3F7;
    margin-bottom: 0.85rem;
  }

  /* ── About ── */
  .about {
    max-width: 1080px;
    margin: 5.5rem auto 0;
    padding-top: 5.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    display: grid;
    grid-template-columns: 280px 1fr auto;
    gap: 3.5rem;
    align-items: center;
  }

  .about-portrait {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border: 1px solid rgba(255, 107, 53, 0.2);
  }

  .about-portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .portrait-placeholder {
    display: none;
    width: 100%;
    height: 100%;
    background:
      repeating-linear-gradient(45deg, rgba(210,153,146,0.04) 0 12px, transparent 12px 24px),
      rgba(255, 255, 255, 0.03);
    align-items: center;
    justify-content: center;
  }

  .portrait-placeholder span {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .about-text {
    text-align: center;
  }

  .about-text h2 {
    font-size: clamp(2rem, 3.5vw, 3rem);
    color: #ffffff;
    font-weight: 400;
    margin-bottom: 1.25rem;
    line-height: 1.1;
    letter-spacing: -0.01em;
  }

  .about-text p {
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.62);
    line-height: 1.85;
    margin-bottom: 1.1rem;
  }

  .about-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .about-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 0.2s;
  }

  .about-link:hover { color: #E96530; }
  .about-link.no-link { cursor: default; }
  .about-link span { font-size: 0.9rem; }

  /* ── Contact head ── */
  .contact-head {
    max-width: 1080px;
    margin: 0 auto 2.5rem;
    text-align: center;
  }

  .contact-head h2 {
    font-size: clamp(2rem, 3.5vw, 3rem);
    color: #ffffff;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin-bottom: 1rem;
  }

  .contact-sub {
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.8;
    max-width: 38rem;
    margin: 0 auto;
  }

  /* ── Form wrap ── */
  .form-wrap {
    max-width: 1080px;
    margin: 0 auto;
  }

  /* ── Form box (cream) ── */
  .form-box {
    background: #eef2ff;
    border: 1px solid rgba(255, 107, 53, 0.2);
    padding: 2.5rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.1rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-field label {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(13, 17, 23, 0.5);
  }

  .form-field input,
  .form-field select,
  .form-field textarea {
    background: #f5f7ff;
    border: 1px solid rgba(13, 17, 23, 0.15);
    color: #0c1525;
    font-family: 'Inter', sans-serif;
    font-size: 0.88rem;
    padding: 0.7rem 0.85rem;
    outline: none;
    transition: border-color 0.2s;
    resize: vertical;
  }

  .form-field input::placeholder,
  .form-field textarea::placeholder { color: rgba(13, 17, 23, 0.35); }

  .form-field input:focus,
  .form-field select:focus,
  .form-field textarea:focus { border-color: #E96530; }

  .form-field select option { background: #eef2ff; color: #0c1525; }

  .form-submit {
    background: #0c1525;
    color: #ffffff;
    border: none;
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.95rem;
    cursor: pointer;
    transition: background 0.2s;
    margin-top: 0.35rem;
  }

  .form-submit:hover { background: #1a2235; }
  .form-submit:disabled { opacity: 0.6; cursor: default; }

  /* Honeypot — hidden from real users */
  .contact-hp { position: absolute; left: -9999px; opacity: 0; pointer-events: none; }

  .form-error {
    color: #c0392b;
    font-size: 0.82rem;
    line-height: 1.6;
    margin-top: 0.75rem;
  }

  /* ── Inline success state ── */
  .form-success {
    text-align: center;
    padding: 1rem 0.5rem;
  }

  .form-success-tick {
    width: 3rem;
    height: 3rem;
    margin: 0 auto 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(233, 101, 48, 0.12);
    color: #E96530;
    font-size: 1.4rem;
    font-weight: 700;
  }

  .form-success h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem;
    font-weight: 500;
    color: #0c1525;
    margin-bottom: 0.6rem;
  }

  .form-success p {
    font-size: 0.9rem;
    color: rgba(13, 17, 23, 0.65);
    line-height: 1.7;
    max-width: 24rem;
    margin: 0 auto;
  }

  .whatsapp-line {
    margin-top: 1.5rem;
    font-size: 0.82rem;
    color: rgba(13, 17, 23, 0.6);
    line-height: 1.6;
  }

  .whatsapp-line a {
    color: #d14a25;
    text-decoration: none;
    font-weight: 600;
    border-bottom: 1px solid rgba(209, 74, 37, 0.3);
  }

  .whatsapp-line a:hover { border-color: #d14a25; }

  /* ── Socials ── */
  .socials-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .social-card {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.95rem 1rem;
    background: rgba(255, 107, 53, 0.04);
    border: 1px solid rgba(255, 107, 53, 0.12);
    text-decoration: none;
    overflow: hidden;
    isolation: isolate;
    transition: border-color 0.25s ease, transform 0.25s ease;
  }

  .social-card::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.35;
    transition: opacity 0.25s ease;
  }

  .social-card:hover {
    border-color: rgba(255, 255, 255, 0.25);
    transform: translateX(3px);
  }

  .social-card:hover::before { opacity: 0.7; }

  .social-linkedin::before  { background: linear-gradient(135deg, #0A66C2 0%, #004182 100%); }
  .social-instagram::before { background: linear-gradient(135deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%); }
  .social-facebook::before  { background: linear-gradient(135deg, #1877F2 0%, #0a4fa8 100%); }
  .social-github::before    { background: linear-gradient(135deg, #3a3f47 0%, #1b1f23 100%); }

  .social-icon {
    color: #E96530;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 107, 53, 0.25);
    flex-shrink: 0;
  }

  .social-card:hover .social-icon { color: #ffffff; border-color: rgba(240,236,228,0.4); }

  .social-name { font-size: 0.82rem; color: #ffffff; font-weight: 500; }
  .social-handle { font-size: 0.7rem; color: rgba(255, 255, 255, 0.4); margin-top: 0.1rem; }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .about { grid-template-columns: 1fr; gap: 2rem; }
    .about-portrait { max-width: 280px; aspect-ratio: 3 / 4; }
    .socials { border-top: 1px solid rgba(255, 255, 255, 0.07); padding-top: 2rem; }
    .socials-list { flex-direction: row; flex-wrap: wrap; }
    .social-card { flex: 1 1 160px; }
  }

  @media (max-width: 600px) {
    .contact-section { padding: 5rem 1.25rem 4rem; }
    .form-box { padding: 1.75rem 1.25rem; }
    .form-row { grid-template-columns: 1fr; }
  }

  @media (max-width: 430px) {
    .contact-section { padding: 4rem 1rem 3rem; }
    .form-box         { padding: 1.5rem 1rem; }
    .about-portrait   { max-width: 200px; }
    /* Full-width social cards on tiny phones */
    .social-card      { flex: 1 1 100%; }
    .about-links      { gap: 1rem; }
    .form-submit      { font-size: 0.78rem; }
  }
</style>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement | null;
  const submitBtn = document.getElementById('contactSubmit') as HTMLButtonElement | null;
  const successPane = document.getElementById('contactSuccess');
  const errorEl = document.getElementById('contactError');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (errorEl) errorEl.hidden = true;
    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Sending...'; }

    fetch('https://api.web3forms.com/submit', {
      method: 'POST',
      body: new FormData(form),
    })
      .then((res) => res.json())
      .then((json) => {
        if (!json.success) throw new Error(json.message || 'Submission failed');
        form.hidden = true;
        if (successPane) successPane.hidden = false;
        successPane?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      })
      .catch(() => {
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Send It →'; }
        if (errorEl) {
          errorEl.hidden = false;
          errorEl.textContent =
            "Something went wrong sending that. Please try again, or WhatsApp / email me directly — damien@damienbuilds.dev.";
        }
      });
  });
</script>
