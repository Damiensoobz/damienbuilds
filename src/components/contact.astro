---
const steps = [
  { number: "01", title: "Discovery",          desc: "We have a no-jargon chat about your business goals. Think of it as a vibe check — but for websites." },
  { number: "02", title: "Content Gathering",  desc: "Drop your logo, photos, and whatever copy exists. I'll make it slap. Trust the process." },
  { number: "03", title: "Design & Build",     desc: "This is where I disappear for a bit and come back with something that genuinely goes hard." },
  { number: "04", title: "Review & Revisions", desc: "Two rounds of 'can you make the logo bigger' included. We iterate until it's chef's kiss." },
  { number: "05", title: "Launch",             desc: "We hit send on the internet. Domain, hosting, SSL — I handle the tech so you don't have to Google it." },
  { number: "06", title: "Handover",           desc: "Full doc: every login, every password, every renewal date. No gatekeeping. You own this." },
];
---

<!-- Process Section -->
<section class="process" id="process">
  <div class="process-inner">
    <div class="process-header">
      <!--
        The SVG oval now includes a vertical stroke descending from its
        bottom-centre, acting as the connector line into the steps grid.
        overflow: visible lets it extend below the process-header box.
      -->
      <svg class="cloud-bg" viewBox="0 0 620 230" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="none">
        <path d="M 305,14 C 388,6 476,30 530,76 C 580,118 598,172 578,204 C 560,228 516,234 462,228 C 394,230 314,228 240,220 C 166,212 90,196 48,156 C 8,118 8,68 40,42 C 70,16 130,6 198,8 C 248,10 272,20 305,14 Z" fill="none" stroke="rgba(240,236,228,0.16)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M 310,24 C 386,17 468,40 518,84 C 563,122 576,172 558,200 C 542,223 502,229 452,225 C 387,227 312,225 242,218 C 172,211 100,196 62,160 C 26,126 28,80 58,56 C 86,32 142,22 208,22 C 254,22 278,30 310,24 Z" fill="none" stroke="rgba(240,236,228,0.07)" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <p class="process-label">How It Works</p>
      <h2>From idea to live site —<br/>here's the process.</h2>
    </div>
  </div>

  <div class="steps-grid">

      <!--
        Desktop (3-col 2-row): serpentine through step-number centres.
        Tablet  (2-col 3-row): serpentine adapts to 3 rows.
        Mobile  (1-col 6-row): simple vertical line.
        All use vector-effect="non-scaling-stroke" so the 1.5px stroke stays
        crisp even though the SVG is stretched to fill the grid with
        preserveAspectRatio="none".
      -->

      <!-- Desktop 3-col snake -->
      <svg class="steps-line steps-line--lg"
           viewBox="0 0 100 100" preserveAspectRatio="none"
           xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path
          d="M 17,11 Q 33.5,8.5 50,11 Q 66.5,13.5 83,11
             C 94,11 94,64 83,64
             Q 66.5,66.5 50,64 Q 33.5,61.5 17,64"
          fill="none"
          stroke="rgba(240,236,228,0.18)"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          vector-effect="non-scaling-stroke"
        />
      </svg>

      <!-- Tablet 2-col snake -->
      <svg class="steps-line steps-line--md"
           viewBox="0 0 100 100" preserveAspectRatio="none"
           xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path
          d="M 25,8 Q 50,6 75,8
             C 88,8 88,42 75,42
             Q 50,40 25,42
             C 12,42 12,76 25,76
             Q 50,74 75,76"
          fill="none"
          stroke="rgba(240,236,228,0.18)"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          vector-effect="non-scaling-stroke"
        />
      </svg>

      <!-- Mobile 1-col vertical -->
      <svg class="steps-line steps-line--sm"
           viewBox="0 0 100 100" preserveAspectRatio="none"
           xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <line
          x1="50" y1="7" x2="50" y2="93"
          stroke="rgba(240,236,228,0.18)"
          stroke-width="1.5"
          stroke-linecap="round"
          vector-effect="non-scaling-stroke"
        />
      </svg>

      {steps.map((step) => (
        <div class="step">
          <span class="step-number">{step.number}</span>
          <h3>{step.title}</h3>
          <p>{step.desc}</p>
        </div>
      ))}
    </div>

    <!-- Bouncing arrow pointing down to the contact section -->
    <div class="process-end-arrow">
      <svg viewBox="0 0 24 24" width="22" height="22" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <line x1="12" y1="4" x2="12" y2="18" stroke="rgba(240,236,228,0.45)" stroke-width="1.5" stroke-linecap="round"/>
        <polyline points="6,13 12,19 18,13" fill="none" stroke="rgba(240,236,228,0.45)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>

</section>

<!-- Contact + Footer -->
<section class="contact-footer" id="contact">

  <div class="contact-layout">

    <!-- Left column: socials, outside the box -->
    <aside class="socials-sidebar">
      <p class="sidebar-label">Find Me Online</p>
      <div class="socials-list">

        <a href="#" target="_blank" rel="noopener noreferrer" class="social-card social-linkedin">
          <span class="social-icon">
            <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </span>
          <div>
            <p class="social-name">LinkedIn</p>
            <p class="social-handle">@damienbuilds</p>
          </div>
        </a>

        <a href="#" target="_blank" rel="noopener noreferrer" class="social-card social-instagram">
          <span class="social-icon">
            <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
          </span>
          <div>
            <p class="social-name">Instagram</p>
            <p class="social-handle">@damienbuilds</p>
          </div>
        </a>

        <a href="#" target="_blank" rel="noopener noreferrer" class="social-card social-x">
          <span class="social-icon">
            <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.63L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/></svg>
          </span>
          <div>
            <p class="social-name">X / Twitter</p>
            <p class="social-handle">@damienbuilds</p>
          </div>
        </a>

        <a href="#" target="_blank" rel="noopener noreferrer" class="social-card social-github">
          <span class="social-icon">
            <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          </span>
          <div>
            <p class="social-name">GitHub</p>
            <p class="social-handle">@damienbuilds</p>
          </div>
        </a>

      </div>
    </aside>

    <!-- Right: contact box -->
    <div class="contact-block">
      <div class="contact-inner">

        <!-- About + portrait -->
        <div class="contact-left">
          <p class="contact-label">About</p>
          <h2>Hi, I'm Damien.</h2>
          <p class="contact-sub">
            Durban web designer. I make websites that actually do something —
            no agencies, no middlemen, no Comic Sans. Just clean work, delivered fast.
            My sites are so good my mum showed one to her book club.
          </p>

          <!-- Portrait placeholder — swap src for your real photo -->
          <div class="portrait">
            <img src="/images/portrait.jpg" alt="Damien" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
            <div class="portrait-placeholder">
              <span>Your Photo</span>
            </div>
          </div>

          <div class="contact-links">
            <a href="mailto:damien@damienbuilds.dev" class="contact-link">
              <span class="link-icon">✉</span>
              damien@damienbuilds.dev
            </a>
            <a href="https://wa.me/27000000000" target="_blank" rel="noopener noreferrer" class="contact-link">
              <span class="link-icon">💬</span>
              WhatsApp Me
            </a>
            <span class="contact-link no-link">
              <span class="link-icon">📍</span>
              Durban, South Africa
            </span>
          </div>
        </div>

        <!-- Contact form -->
        <div class="contact-right">
          <p class="contact-label">Get In Touch</p>
          <form class="contact-form" name="contact" method="POST" data-netlify="true">
            <input type="hidden" name="form-name" value="contact" />

            <div class="form-field">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" placeholder="Your name" required />
            </div>
            <div class="form-field">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" placeholder="your@email.com" required />
            </div>

            <div class="form-field">
              <label for="phone">Phone (optional)</label>
              <input type="tel" id="phone" name="phone" placeholder="+27 00 000 0000" />
            </div>

            <div class="form-field">
              <label for="package">Interested in</label>
              <select id="package" name="package">
                <option value="">Select a package</option>
                <option value="starter">Starter — R3,500</option>
                <option value="growth">Growth — R6,500</option>
                <option value="premium">Premium — R10,500</option>
                <option value="unsure">Not sure yet</option>
              </select>
            </div>

            <div class="form-field">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="4" placeholder="Tell me about your business..." required></textarea>
            </div>

            <button type="submit" class="form-submit">Send Message</button>
          </form>
        </div>

      </div>
    </div>

  </div>

  <!-- Footer bar -->
  <div class="footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <div class="footer-logo">
          <img src="/favicon.png" alt="DamienBuilds" />
        </div>
        <div class="footer-brand-text">
          <p class="footer-name">DamienBuilds.dev</p>
          <p class="footer-tagline">Durban Web Design</p>
        </div>
      </div>
      <p class="footer-copy">Helping Durban businesses get found online.<br/>© 2026 DamienBuilds.dev</p>
      <div class="footer-right">
        <div class="footer-links">
          <a href="#services">Services</a>
          <a href="#portfolio">Work</a>
          <a href="#contact">Contact</a>
        </div>
        <p class="footer-legal">Built with Astro · Hosted on Netlify</p>
      </div>
    </div>
  </div>

</section>

<style>
  /* ── Process ── */
  .process {
    background: linear-gradient(180deg, #5B6F85 0%, #4A5872 63%);
    padding: 6rem 2rem;
  }

  .process-inner {
    max-width: 820px;
    margin: 0 auto;
    text-align: center;
  }

  .process-header {
    position: relative;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    padding: 2.5rem 5rem 5rem; /* generous bottom padding so the oval encloses the h2 */
    margin-bottom: 1rem;
  }

  .cloud-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .process-label {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(240, 236, 228, 0.6);
    margin-bottom: 1rem;
    position: relative;
  }

  .process-inner h2 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    color: #f0ece4;
    font-weight: 500;
    margin-bottom: 0;
    line-height: 1.2;
    position: relative;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    text-align: center;
    position: relative; /* stacking context for the SVG line */
  }

  /* ── Connecting journey line SVGs ── */
  .steps-line {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    overflow: visible;
  }

  /* Show only the desktop line by default */
  .steps-line--md,
  .steps-line--sm { display: none; }

  .step {
    position: relative;
    z-index: 1; /* render above the SVG line */
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.75rem 1.25rem;
    background: rgba(20, 32, 50, 0.55);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(240, 236, 228, 0.08);
  }

  .step-number {
    font-family: 'Playfair', serif;
    font-size: 2rem;
    color: rgba(240, 236, 228, 0.18);
    font-weight: 600;
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .step h3 {
    font-family: 'Playfair', serif;
    font-size: 1.05rem;
    color: #f0ece4;
    font-weight: 500;
  }

  .step p {
    font-size: 0.82rem;
    color: rgba(240, 236, 228, 0.6);
    line-height: 1.6;
  }

  /* ── End-of-journey arrow ── */
  .process-end-arrow {
    display: flex;
    justify-content: center;
    margin-top: 2.5rem;
    animation: arrowBounce 2s ease-in-out infinite;
  }

  @keyframes arrowBounce {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(7px); }
  }

  /* ── Contact + Footer wrapper ── */
  .contact-footer {
    background: #142032;
    position: relative;
    padding-bottom: 0;
  }

  /* ── Outer layout: socials sidebar + contact box ── */
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr minmax(0, 700px);
    gap: 2rem;
    max-width: 1080px;
    margin: 0 auto;
    padding: 5rem 2rem 5rem;
    align-items: center;
  }

  /* ── Socials sidebar ── */
  .socials-sidebar {
    justify-self: center;
  }

  .sidebar-label {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(240, 236, 228, 0.4);
    margin-bottom: 1rem;
  }

  .socials-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .social-card {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 0.9rem;
    background: rgba(240, 236, 228, 0.04);
    border: 1px solid rgba(240, 236, 228, 0.08);
    text-decoration: none;
    overflow: hidden;
    isolation: isolate;
    transition: border-color 0.25s ease, transform 0.25s ease;
  }

  /* Platform-themed gradient layer */
  .social-card::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.35;
    transition: opacity 0.25s ease;
  }

  .social-card:hover {
    border-color: rgba(240, 236, 228, 0.25);
    transform: translateX(2px);
  }

  .social-card:hover::before { opacity: 0.65; }

  .social-linkedin::before {
    background: linear-gradient(135deg, #0A66C2 0%, #004182 100%);
  }

  .social-instagram::before {
    background: linear-gradient(135deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
  }

  .social-x::before {
    background: linear-gradient(135deg, #2a2a2a 0%, #000000 100%);
  }

  .social-github::before {
    background: linear-gradient(135deg, #3a3f47 0%, #1b1f23 100%);
  }

  .social-icon {
    color: #a0b4c8;
    width: 1.75rem;
    height: 1.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(160, 180, 200, 0.25);
    flex-shrink: 0;
  }

  .social-icon svg {
    display: block;
  }

  .social-name {
    font-size: 0.78rem;
    color: #f0ece4;
    font-weight: 500;
  }

  .social-handle {
    font-size: 0.68rem;
    color: rgba(240, 236, 228, 0.4);
    margin-top: 0.05rem;
  }

  /* ── Contact box ── */
  .contact-block {
    background: #241d1b;
    padding: 2.5rem;
    min-width: 0;
  }

  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 2.5rem;
    align-items: start;
  }

  /* ── Left: about + portrait ── */
  .contact-label {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #a0b4c8;
    margin-bottom: 0.75rem;
  }

  .contact-left h2 {
    font-size: clamp(1.3rem, 2vw, 1.75rem);
    color: #f0ece4;
    font-weight: 500;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .contact-sub {
    font-size: 0.83rem;
    color: #a0a0a0;
    line-height: 1.75;
    margin-bottom: 1.25rem;
  }

  /* Portrait */
  .portrait {
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    margin-bottom: 1.25rem;
    max-height: 220px;
  }

  .portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .portrait-placeholder {
    display: none;
    width: 100%;
    height: 100%;
    background: rgba(240, 236, 228, 0.05);
    border: 1px dashed rgba(240, 236, 228, 0.15);
    align-items: center;
    justify-content: center;
  }

  .portrait-placeholder span {
    font-size: 0.75rem;
    color: rgba(240, 236, 228, 0.3);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-size: 0.8rem;
    color: #c0bdb8;
    text-decoration: none;
    transition: color 0.2s;
  }

  .contact-link:hover { color: #f0ece4; }
  .no-link { cursor: default; }

  .link-icon {
    font-size: 0.9rem;
    width: 1rem;
    text-align: center;
  }

  /* ── Right: form ── */
  .contact-right {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-width: 0;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .form-field label {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #a0a0a0;
  }

  .form-field input,
  .form-field select,
  .form-field textarea {
    background: rgba(240, 236, 228, 0.05);
    border: 1px solid rgba(240, 236, 228, 0.12);
    color: #f0ece4;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.88rem;
    padding: 0.65rem 0.85rem;
    outline: none;
    transition: border-color 0.2s;
    resize: vertical;
  }

  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: rgba(240, 236, 228, 0.3);
  }

  .form-field input:focus,
