---
---

<section class="work" id="work">
  <div class="work-inner">

    <div class="work-header">
      <p class="work-label">Work</p>
      <h2>What We've Built</h2>
    </div>

    <div class="banner">
      <div class="banner-image">
        <!-- Swap this placeholder for your propaganda-style poster image -->
        <img src="/images/founding-poster.jpg" alt="This could be you" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
        <div class="image-placeholder">
          <span class="ph-tag">🚧 Reserved</span>
          <p class="ph-title">Your Site Here</p>
          <p class="ph-sub">A poster goes here until the first case studies land.</p>
        </div>
      </div>

      <div class="banner-content">
        <p class="banner-eyebrow">🚧 This Spot Is Reserved For You</p>
        <p class="banner-lead">Real talk: I'm new to running this independently, so this space is empty on purpose — I'd rather show you nothing than fake it with stock photos and made-up testimonials.</p>
        <p class="banner-body">So here's the deal. I'm taking on <strong>3 founding clients at R4,500</strong> instead of R6,500. Same build, same quality, same full handover. All I ask in return is honest feedback and permission to feature your site right here.</p>
        <p class="banner-kicker">You get a proper website at a founder's price. I get a portfolio that's actually real. Nobody gets Comic Sans.</p>
        <a href="#contact" class="banner-cta">Claim a Founding Spot →</a>
        <p class="banner-small">2 spots remaining. Once they're gone, it's full price.</p>
      </div>
    </div>

  </div>
</section>

<style>
  .work {
    background: #112038;
    padding: 7rem 2rem 6rem;
    color: #ffffff;
  }

  .work-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ── Header ── */
  .work-header { margin-bottom: 3.5rem; text-align: center; }

  .work-label {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #4FC3F7;
    margin-bottom: 0.85rem;
  }

  .work-header h2 {
    font-size: clamp(2.2rem, 4.5vw, 3.6rem);
    font-weight: 400;
    color: #ffffff;
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  /* ── Banner ── */
  .banner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3.5rem;
    align-items: center;
  }

  .banner-image {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border: 1px solid rgba(255, 107, 53, 0.2);
  }

  .banner-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .image-placeholder {
    width: 100%;
    height: 100%;
    background:
      repeating-linear-gradient(45deg, rgba(210,153,146,0.04) 0 12px, transparent 12px 24px),
      linear-gradient(135deg, rgba(255, 107, 53, 0.12), rgba(255, 107, 53, 0.03));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    text-align: center;
    padding: 2rem;
  }

  .ph-tag {
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #E96530;
    border: 1px solid rgba(255, 107, 53, 0.35);
    padding: 0.3rem 0.7rem;
  }

  .ph-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    font-weight: 300;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .ph-sub {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.3);
    line-height: 1.5;
    max-width: 16rem;
  }

  /* ── Banner content ── */
  .banner-content {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    text-align: center;
    align-items: center;
  }

  .banner-eyebrow {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 400;
    color: #ffffff;
    line-height: 1.15;
    letter-spacing: -0.01em;
  }

  .banner-lead {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.8;
  }

  .banner-body {
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.8;
  }

  .banner-body strong { color: #E96530; font-weight: 600; }

  .banner-kicker {
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.7;
    font-style: italic;
  }

  .banner-cta {
    display: inline-block;
    width: fit-content;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #0d1117;
    background: #E96530;
    text-decoration: none;
    padding: 0.9rem 2.25rem;
    margin-top: 0.5rem;
    transition: background 0.2s, transform 0.2s;
  }

  .banner-cta:hover { background: #FF8C5A; transform: translateY(-1px); }

  .banner-small {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.4);
    letter-spacing: 0.03em;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .banner { grid-template-columns: 1fr; gap: 2.5rem; }
    .banner-image { aspect-ratio: 16 / 10; max-height: 360px; }
  }

  @media (max-width: 560px) {
    .work { padding: 5rem 1.25rem 4rem; }
    .work-header { margin-bottom: 2.5rem; }
  }
</style>
