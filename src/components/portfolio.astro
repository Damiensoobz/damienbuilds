---
const projects = [
  {
    title: "Plumbing Bros",
    description: "Starter site for a Durban plumber who was tired of losing jobs to Google's top 3. Spoiler: now he IS the top 3.",
    testimonial: "\"My diary is booked three months out. Please send help.\" — Brad T.",
    image: "/images/cloudsbg.jpg",
    url: "#",
    tag: "Starter Package"
  },
  {
    title: "The Hungry Bean",
    description: "Growth package for a café that was completely invisible online. Now regulars quote their own WhatsApp menu back at them.",
    testimonial: "\"We had to hire two extra staff. This is not a complaint.\" — Naledi M.",
    image: "/images/cloudsbg.jpg",
    url: "#",
    tag: "Main Character Package"
  },
  {
    title: "Volt & Sparks",
    description: "Premium build for an electrician who said 'I don't need a website' in 2022. He called us in 2025. He ranked page one in six weeks.",
    testimonial: "\"I'm obsessed with my own website. Is that weird?\" — Grant K.",
    image: "/images/cloudsbg.jpg",
    url: "#",
    tag: "Full Send Package"
  },
];
---

<section class="portfolio" id="portfolio">
  <div class="slider-wrapper">

    <!-- Shown above the slider on mobile only -->
    <div class="portfolio-header-mobile">
      <p class="portfolio-label">Recent Work</p>
      <h2>What We've Built</h2>
    </div>

    <div class="slides-container">

      <!-- Overlaid on the right info-panel area on desktop only -->
      <div class="portfolio-header">
        <p class="portfolio-label">Recent Work</p>
        <h2>What We've Built</h2>
      </div>

      {projects.map((project, i) => (
        <div class={`slide ${i === 0 ? 'active' : ''}`} data-index={i}>

          <!-- Clickable image with zoom effect -->
          <a
            class="slide-image"
            href={project.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`View live site: ${project.title}`}
          >
            <img src={project.image} alt={project.title} />
            <div class="slide-overlay"></div>
          </a>

          <!-- Right-side info panel -->
          <div class="slide-info">
            <span class="slide-tag">{project.tag}</span>
            <h3>{project.title}</h3>
            <p class="slide-desc">{project.description}</p>
            <a href={project.url} target="_blank" rel="noopener noreferrer" class="slide-link">
              View Live Site →
            </a>
            <div class="slide-divider"></div>
            <p class="slide-testimonial">{project.testimonial}</p>
          </div>

        </div>
      ))}

      <button class="nav-btn prev" id="prevBtn" aria-label="Previous project">&#8592;</button>
      <button class="nav-btn next" id="nextBtn" aria-label="Next project">&#8594;</button>

    </div>

    <div class="slide-dots">
      {projects.map((_, i) => (
        <button class={`dot ${i === 0 ? 'active' : ''}`} data-dot={i} aria-label={`Go to project ${i + 1}`}></button>
      ))}
    </div>

  </div>
</section>

<style>
  .portfolio {
    background: linear-gradient(180deg, #B38782 0%, #5B6F85 63%);
    padding: 3rem 0 4.5rem;
  }

  .slider-wrapper {
    position: relative;
    width: 100%;
  }

  /* ── Mobile-only header (hidden on desktop) ── */
  .portfolio-header-mobile {
    display: none;
    text-align: center;
    padding: 1.5rem 1rem 1.25rem;
    pointer-events: none;
  }

  .portfolio-header-mobile .portfolio-label {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(240, 236, 228, 0.75);
    margin-bottom: 0.6rem;
  }

  .portfolio-header-mobile h2 {
    font-size: clamp(1.6rem, 5vw, 2.2rem);
    color: #f0ece4;
    font-weight: 500;
  }

  /* ── Slides container ── */
  .slides-container {
    position: relative;
    width: 90%;
    max-width: 1400px;
    height: 640px;
    margin: 0 auto;
    overflow: hidden;
  }

  /* ── Desktop header: sits over the right info-panel area ── */
  .portfolio-header {
    position: absolute;
    top: 1.75rem;
    right: 0;
    width: 360px;
    z-index: 6;
    pointer-events: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 1.75rem; /* mirrors slide-info horizontal padding */
  }

  .portfolio-label {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(240, 236, 228, 0.75);
    margin-bottom: 0.5rem;
  }

  .portfolio-header h2 {
    font-size: 1.5rem;
    color: #f0ece4;
    font-weight: 500;
    line-height: 1.2;
  }

  /* ── Individual slide ── */
  .slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .slide.active {
    opacity: 1;
    pointer-events: all;
  }

  /* ── Clickable background image with zoom ── */
  .slide-image {
    position: absolute;
    inset: 0;
    display: block;
    overflow: hidden;
    cursor: pointer;
    text-decoration: none;
  }

  .slide-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.7s ease;
  }

  .slide.active .slide-image:hover img {
    transform: scale(1.06);
  }

  .slide-overlay {
    position: absolute;
    inset: 0;
    background: rgba(15, 20, 35, 0.18);
    transition: background 0.3s ease;
  }

  .slide.active .slide-image:hover .slide-overlay {
    background: rgba(15, 20, 35, 0.08);
  }

  /* ── Right info panel ── */
  .slide-info {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    width: 360px;
    background: rgba(240, 236, 228, 0.1);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-left: 1px solid rgba(240, 236, 228, 0.18);
    padding: 6rem 1.75rem 2.5rem; /* top padding clears the desktop header */
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: stretch; /* stretch so text fills width and wraps properly */
    text-align: center;
    gap: 0.9rem;
  }

  /* Push content block away from the header — centres it in the remaining space */
  .slide-tag {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(240, 236, 228, 0.6);
    margin-top: auto;
    align-self: center; /* tag is short — keep it centered, not stretched */
  }

  .slide-info h3 {
    font-family: 'Playfair', serif;
    font-size: 1.35rem;
    color: #f0ece4;
    font-weight: 500;
  }

  .slide-desc {
    font-size: 0.85rem;
    color: rgba(240, 236, 228, 0.8);
    line-height: 1.6;
  }

  .slide-link {
    display: inline-block;
    margin-top: 0.25rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: rgba(240, 236, 228, 0.75);
    text-decoration: none;
    border-bottom: 1px solid rgba(240, 236, 228, 0.3);
    padding-bottom: 0.1rem;
    transition: color 0.2s;
    align-self: center; /* keep link at natural width, centered */
  }

  .slide-link:hover { color: #f0ece4; }

  .slide-divider {
    width: 50%;
    height: 1px;
    background: rgba(240, 236, 228, 0.2);
    margin: 0.5rem 0 0.3rem;
    margin-top: auto; /* anchors the divider + testimonial to the bottom */
    align-self: center; /* 50% width — must opt out of stretch */
  }

  .slide-testimonial {
    font-size: 0.85rem;
    color: #f0ece4;
    line-height: 1.6;
    font-style: italic;
    opacity: 0.85;
  }

  /* ── Nav buttons ── */
  .nav-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 44px;
    height: 44px;
    background: rgba(240, 236, 228, 0.1);
    border: 1px solid rgba(240, 236, 228, 0.25);
    color: #f0ece4;
    font-size: 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, border-color 0.2s;
    padding: 0;
  }

  .nav-btn:hover {
    background: rgba(240, 236, 228, 0.22);
    border-color: rgba(240, 236, 228, 0.5);
  }

  .prev { left: 2.5rem; }
  /* next stays in the image area, clear of the 360px right panel */
  .next { right: calc(360px + 2.5rem + 44px); }

  /* ── Dots ── */
  .slide-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.75rem;
  }

  .dot {
    width: 8px;
    height: 8px;
    background: rgba(240, 236, 228, 0.25);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s;
  }

  .dot.active { background: #f0ece4; }

  /* ── Tablet / mobile ── */
  @media (max-width: 900px) {
    .portfolio { padding: 0 0 3rem; }

    /* Show mobile header, hide desktop header */
    .portfolio-header-mobile { display: block; }
    .portfolio-header { display: none; }

    /*
      Stacked layout: image zone (top 240px) + info zone (remaining 310px).
      slides-container total = 550px. Extra info height prevents text cutoff.
    */
    .slides-container {
      width: 92%;
      height: 550px;
    }

    /*
      Constrain the image to the top zone only.
      Override inset: 0 — keep top/left/right at 0, but fix height instead of stretching to bottom.
    */
    .slide-image {
      bottom: auto;
      height: 240px;
    }

    /* Reset desktop-only overrides */
    .slide-tag { margin-top: 0; align-self: stretch; }
    .slide-link { align-self: center; }
    .slide-divider { margin-top: 0.3rem; align-self: center; }

    /* Info panel: clean block below the image with enough room for all content */
    .slide-info {
      top: 240px;
      left: 0;
      right: 0;
      bottom: 0;
      width: 100%;
      padding: 1.5rem 1.5rem 1.5rem;
      border-left: none;
      border-top: 1px solid rgba(240, 236, 228, 0.18);
      justify-content: center;
      gap: 0.55rem;
    }

    /* Arrows vertically centred within the image zone */
    .nav-btn {
      top: 120px; /* centre of 240px image zone */
      transform: translateY(-50%);
      width: 38px;
      height: 38px;
    }

    .prev { left: 1rem; }
    .next { right: 1rem; }
  }

  /* ── Small mobile ── */
  @media (max-width: 600px) {
    .slides-container { width: 94%; height: 540px; }

    .slide-image { height: 220px; }

    .slide-info { top: 220px; padding: 1.25rem 1.25rem 1.25rem; gap: 0.45rem; }

    .nav-btn {
      top: 110px;
      width: 34px;
      height: 34px;
    }

    .slide-desc { font-size: 0.8rem; }
    .slide-testimonial { font-size: 0.78rem; }
    .slide-info h3 { font-size: 1.1rem; }
  }
</style>

<script>
  const slides  = document.querySelectorAll('.slide');
  const dots    = document.querySelectorAll('.dot');
  const prevBtn = document.getElementById('prevBtn');
  const nextBtn = document.getElementById('nextBtn');
  let current = 0;

  function goTo(index) {
    slides[current].classList.remove('active');
    dots[current].classList.remove('active');
    current = (index + slides.length) % slides.length;
    slides[current].classList.add('active');
    dots[current].classList.add('active');
  }

  prevBtn?.addEventListener('click', () => goTo(current - 1));
  nextBtn?.addEventListener('click', () => goTo(current + 1));
  dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
</script>
