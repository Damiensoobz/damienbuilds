---
const steps = [
  {
    number: "01", title: "Discovery",
    desc: "We have a no-jargon chat about your business, your goals, and what you actually need (which is sometimes less than you think). Consider it a vibe check — for your website.",
    glyphColor: "#FF6B35",
    icon: `<circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>`,
  },
  {
    number: "02", title: "Content Gathering",
    desc: "Send me your logo, photos, and whatever words you've got. No logo? No copy? Genuinely fine — half my job is making something out of \"I'll know it when I see it.\"",
    glyphColor: "#F59E0B",
    icon: `<polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/>`,
  },
  {
    number: "03", title: "Design & Build",
    desc: "I go quiet for a bit and come back with something that looks like you paid more than you did. Modern tech under the hood, fast by default, built for the people you're trying to reach.",
    glyphColor: "#10B981",
    icon: `<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>`,
  },
  {
    number: "04", title: "Review & Revisions",
    desc: "Two rounds of feedback, included. We go back and forth until it's right. And yes — \"can you make the logo bigger\" is a fully valid note. It always is.",
    glyphColor: "#22D3EE",
    icon: `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>`,
  },
  {
    number: "05", title: "Launch",
    desc: "Domain, hosting, SSL — I handle the technical side so you never have to learn what an A-record is or why it's \"still propagating.\"",
    glyphColor: "#818CF8",
    icon: `<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>`,
  },
  {
    number: "06", title: "Handover",
    desc: "You get one document with every login, every password, and every renewal date. No gatekeeping. You own this outright — that's the whole point.",
    glyphColor: "#A855F7",
    icon: `<path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/>`,
  },
];
---

<section class="process" id="process">
  <!-- Blobs clipped in their own layer so .process can be overflow:visible -->
  <div class="process-blob-clip">
    <div class="process-blob pb-1"></div>
    <div class="process-blob pb-2"></div>
    <div class="process-blob pb-3"></div>
    <div class="process-blob pb-4"></div>
    <div class="process-blob pb-5"></div>
    <div class="process-blob pb-6"></div>
  </div>

  <div class="process-inner">
    <div class="process-header">
      <p class="process-label">How It Works</p>
      <h2>From idea to live site —<br/>here's exactly how it goes.</h2>
    </div>
  </div>

  <div class="steps-timeline">
    {steps.map((step, i) => (
      <div class={`step ${i % 2 === 0 ? 'step--left' : 'step--right'}`} style={`--glyph: ${step.glyphColor}`}>
        <div class="step-content">
          <svg class="step-glyph" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={step.icon}></svg>
          <span class="step-number">{step.number}</span>
          <h3>{step.title}</h3>
          <p>{step.desc}</p>
        </div>
        <div class="step-node">
          <div class="step-dot">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="38" height="38" aria-hidden="true" set:html={step.icon}></svg>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .process {
    position: relative;
    overflow: visible;
    background: linear-gradient(160deg, #1a2840 0%, #0e1c32 40%, #091420 72%, #0a1e36 100%);
    padding: 6rem 2rem 13rem;
    color: #ffffff;
  }

  /* Clips blobs without clipping the wave overlap */
  .process-blob-clip {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  /* ── Process aurora blobs — white by default, coloured on step hover ── */
  .process-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(65px);
    pointer-events: none;
    z-index: 0;
    will-change: transform, opacity;
    transition: background 1.2s ease;
  }

  .pb-1 {
    width: 500px; height: 500px;
    background: rgba(255, 255, 255, 0.12);
    top: -100px; right: -80px;
    animation: pbDrift1 18s ease-in-out infinite;
  }

  .pb-2 {
    width: 380px; height: 380px;
    background: rgba(255, 255, 255, 0.10);
    bottom: -60px; left: 10%;
    animation: pbDrift2 22s ease-in-out infinite;
  }

  .pb-3 {
    width: 300px; height: 300px;
    background: rgba(255, 255, 255, 0.08);
    top: 45%; left: 55%;
    animation: pbDrift3 14s ease-in-out infinite;
  }

  .pb-4 {
    width: 420px; height: 420px;
    background: rgba(255, 255, 255, 0.07);
    top: 25%; left: -80px;
    animation: pbDrift2 26s ease-in-out infinite reverse;
  }

  .pb-5 {
    width: 260px; height: 260px;
    background: rgba(255, 255, 255, 0.09);
    top: 68%; right: 5%;
    animation: pbDrift1 20s ease-in-out infinite reverse;
  }

  .pb-6 {
    width: 350px; height: 350px;
    background: rgba(255, 255, 255, 0.06);
    top: 50%; left: 30%;
    animation: pbDrift3 30s ease-in-out infinite;
  }

  @keyframes pbDrift1 {
    0%, 100% { transform: translate(0,     0)    scale(1);    opacity: 0.75; }
    33%       { transform: translate(-180px, 120px) scale(1.15); opacity: 1;    }
    66%       { transform: translate(-60px,  220px) scale(0.85); opacity: 0.6;  }
  }

  @keyframes pbDrift2 {
    0%, 100% { transform: translate(0,    0)     scale(1);    opacity: 0.65; }
    40%       { transform: translate(160px, -100px) scale(1.1);  opacity: 0.95; }
    70%       { transform: translate(80px,  -200px) scale(0.8);  opacity: 0.5;  }
  }

  @keyframes pbDrift3 {
    0%, 100% { transform: translate(0,    0)    scale(1);    opacity: 0.7;  }
    25%       { transform: translate(-150px, 80px) scale(1.25); opacity: 1;    }
    60%       { transform: translate(100px, 150px) scale(0.7);  opacity: 0.45; }
  }

  .process-inner {
    position: relative;
    z-index: 2;
    max-width: 820px;
    margin: 0 auto;
    text-align: center;
    margin-bottom: 4rem;
  }

  .process-label {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #4FC3F7;
    margin-bottom: 1rem;
  }

  .process-inner h2 {
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    color: #ffffff;
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.01em;
  }

  /* ── Timeline ── */
  .steps-timeline {
    position: relative;
    z-index: 2;
    max-width: 960px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .steps-timeline::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 1px;
    transform: translateX(-50%);
    background: linear-gradient(to bottom,
      transparent,
      rgba(233, 101, 48, 0.3) 5%,
      rgba(233, 101, 48, 0.3) 95%,
      transparent
    );
    pointer-events: none;
    z-index: 0;
  }

  .step {
    display: grid;
    grid-template-columns: 1fr 4.5rem 1fr;
    align-items: flex-start;
    margin-bottom: 3.5rem;
  }

  .step--left  .step-content { grid-column: 1; grid-row: 1; }
  .step--left  .step-node    { grid-column: 2; grid-row: 1; }
  .step--right .step-content { grid-column: 3; grid-row: 1; }
  .step--right .step-node    { grid-column: 2; grid-row: 1; }

  /* ── Node ── */
  .step-node {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding-top: 1.75rem;
    position: relative;
    z-index: 2;
  }

  .step-dot {
    width: 4.5rem;
    height: 4.5rem;
    border-radius: 50%;
    background: var(--glyph);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #0d1117;
    box-shadow: 0 0 24px color-mix(in srgb, var(--glyph) 35%, transparent);
    transition: box-shadow 0.3s ease, transform 0.25s ease;
    flex-shrink: 0;
  }

  .step:hover .step-dot,
  .step.is-active .step-dot {
    box-shadow: 0 0 28px color-mix(in srgb, var(--glyph) 55%, transparent);
    transform: scale(1.1);
  }

  /* ── Content card ── */
  .step-content {
    position: relative;
    overflow: hidden;
    background: #112038;
    border: 1px solid rgba(255, 255, 255, 0.07);
    padding: 2rem;
    transition: border-color 0.3s, transform 0.25s, box-shadow 0.3s;
  }

  .step:hover .step-content,
  .step.is-active .step-content {
    border-color: color-mix(in srgb, var(--glyph) 40%, transparent);
    box-shadow: 0 4px 28px color-mix(in srgb, var(--glyph) 8%, transparent);
    transform: translateY(-2px);
  }

  /* ── Glyph watermark ── */
  .step-glyph {
    position: absolute;
    bottom: -1rem;
    right: -1rem;
    width: 110px;
    height: 110px;
    color: var(--glyph);
    opacity: 0.07;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .step:hover .step-glyph,
  .step.is-active .step-glyph { opacity: 0.15; }

  .step-number {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    color: var(--glyph);
    opacity: 0.7;
    font-weight: 400;
    line-height: 1;
    margin-bottom: 0.5rem;
    transition: opacity 0.3s ease;
  }

  .step:hover .step-number,
  .step.is-active .step-number { opacity: 1; }

  .step-content h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem;
    color: #ffffff;
    font-weight: 500;
    margin-bottom: 0.6rem;
    line-height: 1.2;
  }

  .step-content p {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.7;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    /* Keep bottom padding ≥ wave overlap (180px) so last step isn't hidden under the wave */
    .process { padding: 5rem 1.25rem 12rem; }

    .steps-timeline { padding: 0 0.75rem; }

    .steps-timeline::before {
      left: 2.25rem;
      transform: none;
    }

    .step,
    .step--left,
    .step--right {
      display: grid;
      grid-template-columns: 3.5rem 1fr;
      margin-bottom: 2.5rem;
    }

    .step--left  .step-content,
    .step--right .step-content {
      grid-column: 2;
      grid-row: 1;
    }

    .step--left  .step-node,
    .step--right .step-node {
      grid-column: 1;
      grid-row: 1;
      padding-top: 1.75rem;
      justify-content: center;
    }

    .step-dot { width: 3.5rem; height: 3.5rem; }
  }

  @media (max-width: 430px) {
    .process         { padding: 4rem 0.75rem 12rem; }
    .process-inner   { margin-bottom: 2.5rem; padding: 0 0.5rem; }
    .steps-timeline  { padding: 0; }
    .steps-timeline::before { left: 1.85rem; }
    .step,
    .step--left,
    .step--right     { grid-template-columns: 3rem 1fr; margin-bottom: 2rem; }
    .step-dot        { width: 3rem; height: 3rem; }
    .step-content    { padding: 1.5rem 1.25rem; }
    .step-glyph      { width: 80px; height: 80px; bottom: -0.5rem; right: -0.5rem; }
    .step-number     { font-size: 1.5rem; }
    .step-content h3 { font-size: 1.15rem; }
  }
</style>

<script>
  function hexToRgba(hex: string, alpha: number): string {
    const r = parseInt(hex.slice(1, 3), 16);
    const g = parseInt(hex.slice(3, 5), 16);
    const b = parseInt(hex.slice(5, 7), 16);
    return `rgba(${r}, ${g}, ${b}, ${alpha})`;
  }

  const blobs  = Array.from(document.querySelectorAll<HTMLElement>('.process-blob'));
  const steps  = Array.from(document.querySelectorAll<HTMLElement>('.step'));
  const alphas = [0.45, 0.35, 0.28, 0.25, 0.32, 0.20];
  const whites = ['rgba(255,255,255,0.12)', 'rgba(255,255,255,0.10)', 'rgba(255,255,255,0.08)', 'rgba(255,255,255,0.07)', 'rgba(255,255,255,0.09)', 'rgba(255,255,255,0.06)'];

  let scrollActiveStep: HTMLElement | null = null;
  let hoverActiveStep:  HTMLElement | null = null;

  function setBlobs(step: HTMLElement | null) {
    if (step) {
      const color = getComputedStyle(step).getPropertyValue('--glyph').trim();
      blobs.forEach((blob, i) => { blob.style.background = hexToRgba(color, alphas[i]); });
    } else {
      blobs.forEach((blob, i) => { blob.style.background = whites[i]; });
    }
  }

  function getScrollActive(): HTMLElement | null {
    const trigger = window.innerHeight * 0.55;
    let active: HTMLElement | null = null;
    for (const step of steps) {
      if (step.getBoundingClientRect().top <= trigger) active = step;
    }
    return active;
  }

  function updateScrollActive() {
    const newActive = getScrollActive();
    if (newActive === scrollActiveStep) return;
    steps.forEach(s => s.classList.remove('is-active'));
    if (newActive) newActive.classList.add('is-active');
    scrollActiveStep = newActive;
    if (!hoverActiveStep) setBlobs(scrollActiveStep);
  }

  steps.forEach(step => {
    step.addEventListener('mouseenter', () => {
      hoverActiveStep = step;
      setBlobs(step);
    });
    step.addEventListener('mouseleave', () => {
      hoverActiveStep = null;
      setBlobs(scrollActiveStep);
    });
  });

  window.addEventListener('scroll', updateScrollActive, { passive: true });
  updateScrollActive();
</script>
