---
const steps = [
  {
    number: "01", title: "Discovery",
    desc: "We have a no-jargon chat about your business, your goals, and what you actually need (which is sometimes less than you think). Consider it a vibe check — for your website.",
    glyphColor: "#FF6B35",
    icon: `<circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>`,
  },
  {
    number: "02", title: "Content Gathering",
    desc: "Send me your logo, photos, and whatever words you've got. No logo? No copy? Genuinely fine — half my job is making something out of \"I'll know it when I see it.\"",
    glyphColor: "#F59E0B",
    icon: `<polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/>`,
  },
  {
    number: "03", title: "Design & Build",
    desc: "I go quiet for a bit and come back with something that looks like you paid more than you did. Modern tech under the hood, fast by default, built for the people you're trying to reach.",
    glyphColor: "#10B981",
    icon: `<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>`,
  },
  {
    number: "04", title: "Review & Revisions",
    desc: "Two rounds of feedback, included. We go back and forth until it's right. And yes — \"can you make the logo bigger\" is a fully valid note. It always is.",
    glyphColor: "#22D3EE",
    icon: `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>`,
  },
  {
    number: "05", title: "Launch",
    desc: "Domain, hosting, SSL — I handle the technical side so you never have to learn what an A-record is or why it's \"still propagating.\"",
    glyphColor: "#818CF8",
    icon: `<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>`,
  },
  {
    number: "06", title: "Handover",
    desc: "You get one document with every login, every password, and every renewal date. No gatekeeping. You own this outright — that's the whole point.",
    glyphColor: "#A855F7",
    icon: `<path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/>`,
  },
];
---

<section class="process" id="process">
  <div class="process-inner">
    <div class="process-header">
      <p class="process-label">How It Works</p>
      <h2>From idea to live site —<br/>here's exactly how it goes.</h2>
    </div>
  </div>

  <div class="steps-timeline">
    {steps.map((step, i) => (
      <div class={`step ${i % 2 === 0 ? 'step--left' : 'step--right'}`} style={`--glyph: ${step.glyphColor}`}>
        <div class="step-content">
          <svg class="step-glyph" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={step.icon}></svg>
          <span class="step-number">{step.number}</span>
          <h3>{step.title}</h3>
          <p>{step.desc}</p>
        </div>
        <div class="step-node">
          <div class="step-dot">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true" set:html={step.icon}></svg>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .process {
    background: #0d1117;
    padding: 6rem 2rem 5rem;
    color: #e8edf8;
  }

  .process-inner {
    max-width: 820px;
    margin: 0 auto;
    text-align: center;
    margin-bottom: 4rem;
  }

  .process-label {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #FF6B35;
    margin-bottom: 1rem;
  }

  .process-inner h2 {
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    color: #e8edf8;
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.01em;
  }

  /* ── Timeline ── */
  .steps-timeline {
    position: relative;
    max-width: 960px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .steps-timeline::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 1px;
    transform: translateX(-50%);
    background: linear-gradient(to bottom,
      transparent,
      rgba(255, 107, 53, 0.3) 5%,
      rgba(255, 107, 53, 0.3) 95%,
      transparent
    );
    pointer-events: none;
    z-index: 0;
  }

  .step {
    display: grid;
    grid-template-columns: 1fr 4.5rem 1fr;
    align-items: flex-start;
    margin-bottom: 3.5rem;
  }

  .step--left  .step-content { grid-column: 1; grid-row: 1; }
  .step--left  .step-node    { grid-column: 2; grid-row: 1; }
  .step--right .step-content { grid-column: 3; grid-row: 1; }
  .step--right .step-node    { grid-column: 2; grid-row: 1; }

  /* ── Node ── */
  .step-node {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding-top: 1.75rem;
    position: relative;
    z-index: 2;
  }

  .step-dot {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: var(--glyph);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #0d1117;
    box-shadow: 0 0 18px color-mix(in srgb, var(--glyph) 30%, transparent);
    transition: box-shadow 0.3s ease, transform 0.25s ease;
    flex-shrink: 0;
  }

  .step:hover .step-dot {
    box-shadow: 0 0 28px color-mix(in srgb, var(--glyph) 55%, transparent);
    transform: scale(1.1);
  }

  /* ── Content card ── */
  .step-content {
    position: relative;
    overflow: hidden;
    background: #161d2f;
    border: 1px solid rgba(255, 255, 255, 0.07);
    padding: 2rem;
    transition: border-color 0.3s, transform 0.25s, box-shadow 0.3s;
  }

  .step:hover .step-content {
    border-color: color-mix(in srgb, var(--glyph) 40%, transparent);
    box-shadow: 0 4px 28px color-mix(in srgb, var(--glyph) 8%, transparent);
    transform: translateY(-2px);
  }

  /* ── Glyph watermark ── */
  .step-glyph {
    position: absolute;
    bottom: -1rem;
    right: -1rem;
    width: 110px;
    height: 110px;
    color: var(--glyph);
    opacity: 0.07;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .step:hover .step-glyph { opacity: 0.15; }

  .step-number {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    color: var(--glyph);
    opacity: 0.7;
    font-weight: 400;
    line-height: 1;
    margin-bottom: 0.5rem;
    transition: opacity 0.3s ease;
  }

  .step:hover .step-number { opacity: 1; }

  .step-content h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem;
    color: #e8edf8;
    font-weight: 500;
    margin-bottom: 0.6rem;
    line-height: 1.2;
  }

  .step-content p {
    font-size: 0.82rem;
    color: rgba(232, 237, 248, 0.6);
    line-height: 1.7;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .process { padding: 5rem 1.25rem 4rem; }

    .steps-timeline { padding: 0 1rem; }

    .steps-timeline::before {
      left: 2.5rem;
      transform: none;
    }

    .step,
    .step--left,
    .step--right {
      display: grid;
      grid-template-columns: 3.5rem 1fr;
    }

    .step--left  .step-content,
    .step--right .step-content {
      grid-column: 2;
      grid-row: 1;
    }

    .step--left  .step-node,
    .step--right .step-node {
      grid-column: 1;
      grid-row: 1;
      padding-top: 1.75rem;
      justify-content: center;
    }

    .step-dot { width: 2.5rem; height: 2.5rem; }
  }
</style>
