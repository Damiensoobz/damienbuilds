---
const loadingPhrases = [
  "Reticulating Splines...",
  "Compiling Developer Excuses...",
  "Minifying Tears...",
  "Initializing git blame...",
  "Merging Unresolvable Conflicts...",
  "Inverting Boolean Logic...",
  "Propagating Undefined Behaviour...",
  "Defragmenting Stack Overflow...",
  "Hotfixing Production...",
  "Concatenating Vertex Nodes...",
  "Normalizing npm Vulnerabilities...",
  "Deploying on a Friday...",
  "Calculating Technical Debt...",
  "Calibrating Rubber Duck...",
  "Mapping the Llama Genome...",
  "Invalidating Cache...",
  "Rehydrating Components...",
  "Asserting Dominance over CSS...",
  "Iterating Chaos Array...",
  "Segfaulting Gracefully...",
  "Terraforming localhost...",
  "Summoning the Dark Mode...",
  "Committing Directly to Main...",
  "Overengineering the Solution...",
  "Estimating Two Weeks...",
  "Blaming the Intern...",
  "Rotating the API Keys...",
];
---

<section class="hero" id="hero-section">
  <!-- Aurora background blobs (unchanged) -->
  <div class="aurora-blob blob-1"></div>
  <div class="aurora-blob blob-2"></div>
  <div class="aurora-blob blob-3"></div>
  <div class="aurora-blob blob-4"></div>

  <!-- Editorial layout -->
  <div class="hero-inner">

    <!-- Headline — heavy first line, light remainder -->
    <h1 class="hero-headline">
      <span class="hl-strong">A Website You Own.</span>
      Built by Someone You<br/>Can Actually Reach.
    </h1>

    <!-- Rule flush under headline -->
    <div class="hero-rule"></div>

    <!-- Aside explainer — lead spans full width, body in 2 equal columns -->
    <div class="hero-mid">
      <p class="aside-lead">In 2026, your website is your first impression.</p>
      <div class="aside-cols">
        <div class="aside-col">
          <p class="aside-body">Before a customer calls, books, or buys — they search. If you're not showing up, a competitor who is gets the sale. It's not complicated; it's just how people make decisions now.</p>
          <p class="aside-body">Social media helps, but you don't own it. One algorithm shift, one account ban, one platform dying — and your audience is gone. A website is the only piece of your online presence that is permanently, unconditionally yours.</p>
        </div>
        <div class="aside-col">
          <p class="aside-body">AI search tools are changing how people find businesses too. ChatGPT, Perplexity, Google's AI overviews — they all pull from real websites. No website means no presence in the places your next customer is already looking.</p>
          <p class="aside-body">The businesses that invest in a proper web presence now — fast, clean, actually indexed by Google — are the ones that will be findable when everything else shifts again. And it will shift again.</p>
        </div>
      </div>
    </div>

    <!-- Bottom foot: location left, CTA right -->
    <div class="hero-foot">
      <div class="hero-bottom">
        <p class="hero-secondary">Based in Phoenix, Durban · Building for businesses across South Africa.</p>
        <a href="#contact" class="hero-cta">Let's Build!</a>
      </div>
    </div>

  </div>
</section>

<!-- Loading ticker (unchanged) -->
<div class="loading-banner" aria-label="Loading...">
  <div class="loading-track">
    {[...loadingPhrases, ...loadingPhrases].map((phrase) => (
      <span class="loading-phrase">
        <span class="loading-diamond">◆</span>
        {phrase}
      </span>
    ))}
  </div>
</div>

<style>
  /* ── Hero shell ── */
  .hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    background: linear-gradient(160deg,
      #1a3a5c 0%,
      #0f2040 30%,
      #080f1e 65%,
      #0d1117 100%
    );
    overflow: hidden;
    display: flex;
    flex-direction: column;
    /* height: explicit so flex:1 on hero-inner distributes correctly */
    height: 100vh;
  }

  /* Dot grid texture */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(232, 237, 248, 0.07) 1px, transparent 1px);
    background-size: 28px 28px;
    z-index: 0;
    pointer-events: none;
  }

  /* ── Aurora blobs (unchanged) ── */
  .aurora-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(65px);
    pointer-events: none;
    z-index: 0;
    will-change: transform, opacity;
  }

  .blob-1 {
    width: 480px; height: 480px;
    background: rgba(50, 100, 200, 0.65);
    top: -80px; left: -60px;
    animation: blobDrift1 12s ease-in-out infinite;
  }
  .blob-2 {
    width: 400px; height: 400px;
    background: rgba(255, 80, 20, 0.55);
    bottom: -80px; right: 8%;
    animation: blobDrift2 15s ease-in-out infinite;
  }
  .blob-3 {
    width: 300px; height: 300px;
    background: rgba(120, 40, 200, 0.6);
    top: 40%; left: 40%;
    animation: blobDrift3 10s ease-in-out infinite;
  }
  .blob-4 {
    width: 220px; height: 220px;
    background: rgba(255, 140, 20, 0.45);
    top: 10%; right: 20%;
    animation: blobDrift4 8s ease-in-out infinite;
  }

  @keyframes blobDrift1 {
    0%   { transform: translate(0px,    0px)    scale(1);    opacity: 0.8; }
    25%  { transform: translate(200px,  100px)  scale(1.25); opacity: 1;   }
    50%  { transform: translate(120px,  260px)  scale(0.8);  opacity: 0.6; }
    75%  { transform: translate(-60px,  150px)  scale(1.15); opacity: 0.9; }
    100% { transform: translate(0px,    0px)    scale(1);    opacity: 0.8; }
  }
  @keyframes blobDrift2 {
    0%   { transform: translate(0px,    0px)    scale(1);    opacity: 0.7; }
    30%  { transform: translate(-200px,-140px)  scale(1.2);  opacity: 1;   }
    60%  { transform: translate(-100px,-260px)  scale(0.75); opacity: 0.5; }
    80%  { transform: translate(80px,  -180px)  scale(1.1);  opacity: 0.85;}
    100% { transform: translate(0px,    0px)    scale(1);    opacity: 0.7; }
  }
  @keyframes blobDrift3 {
    0%   { transform: translate(0px,    0px)   scale(1);    opacity: 0.75; }
    20%  { transform: translate(-180px, 140px) scale(1.3);  opacity: 1;    }
    50%  { transform: translate(100px,  200px) scale(0.7);  opacity: 0.5;  }
    75%  { transform: translate(160px, -100px) scale(1.15); opacity: 0.9;  }
    100% { transform: translate(0px,    0px)   scale(1);    opacity: 0.75; }
  }
  @keyframes blobDrift4 {
    0%   { transform: translate(0px,    0px)   scale(1);    opacity: 0.6;  }
    35%  { transform: translate(-120px, 160px) scale(1.4);  opacity: 0.95; }
    65%  { transform: translate(100px,  100px) scale(0.65); opacity: 0.45; }
    100% { transform: translate(0px,    0px)   scale(1);    opacity: 0.6;  }
  }

  /* ── Editorial layout ── */
  .hero-inner {
    position: relative;
    z-index: 5;
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 8rem 6vw 3.5rem;
  }

  /* Horizontal rules */
  .hero-rule {
    width: 100%;
    height: 1px;
    background: rgba(232, 237, 248, 0.14);
    flex-shrink: 0;
  }

  /* Headline — sits at top, natural height, no grow */
  .hero-headline {
    font-size: clamp(3.2rem, 7.8vw, 9.5rem);
    font-weight: 300;
    line-height: 1.0;
    color: #e8edf8;
    letter-spacing: -0.03em;
    padding-bottom: 1.5rem;
    margin: 0;
  }

  .hl-strong {
    font-weight: 800;
    display: block;
  }

  /* ── Aside explainer ── */
  .hero-mid {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 1.75rem 0;
    justify-content: center;
  }

  .aside-lead {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.3rem, 2vw, 1.75rem);
    font-weight: 400;
    line-height: 1.2;
    color: #e8edf8;
    letter-spacing: -0.01em;
    margin: 0;
  }

  /* Two equal columns, body text aligned at the top */
  .aside-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3.5rem;
    align-items: start;
  }

  .aside-col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .aside-body {
    font-size: 0.85rem;
    line-height: 1.8;
    color: rgba(232, 237, 248, 0.52);
    font-weight: 300;
    margin: 0;
  }

  /* Bottom foot */
  .hero-foot {
    flex-shrink: 0;
  }

  .hero-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    padding: 1.5rem 0 0;
  }

  .hero-secondary {
    font-size: 0.68rem;
    color: rgba(232, 237, 248, 0.28);
    letter-spacing: 0.07em;
    margin: 0;
  }

  .hero-cta {
    display: inline-block;
    border: 1px solid rgba(232, 237, 248, 0.4);
    color: #e8edf8;
    background: transparent;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 1.1rem 2.75rem;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .hero-cta:hover {
    border-color: #FF6B35;
    color: #FF6B35;
    background: rgba(255, 107, 53, 0.06);
  }

  /* ── Loading ticker (unchanged) ── */
  .loading-banner {
    position: relative;
    background: #080d14;
    border-top: 1px solid rgba(255, 107, 53, 0.18);
    border-bottom: 1px solid rgba(255, 107, 53, 0.12);
    overflow: hidden;
    padding: 1.6rem 0;
  }

  .loading-banner::before,
  .loading-banner::after {
    content: '';
    position: absolute;
    top: 0; bottom: 0;
    width: calc(100vw / 3);
    z-index: 2;
    pointer-events: none;
  }
  .loading-banner::before { left: 0;  background: linear-gradient(to right, #080d14 30%, transparent); }
  .loading-banner::after  { right: 0; background: linear-gradient(to left,  #080d14 30%, transparent); }

  .loading-track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: loadingTicker 80s linear infinite;
  }
  .loading-banner:hover .loading-track { animation-play-state: paused; }

  @keyframes loadingTicker {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .loading-phrase {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    width: calc(100vw / 3);
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 1rem;
    color: rgba(232, 237, 248, 0.55);
    letter-spacing: 0.04em;
    white-space: nowrap;
    cursor: default;
    flex-shrink: 0;
  }

  .loading-diamond {
    color: #FF6B35;
    font-size: 0.6rem;
    opacity: 0.7;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero-inner  { padding: 6rem 1.5rem 2.5rem; }
    .hero-headline { font-size: clamp(2.6rem, 10vw, 4rem); padding-bottom: 1rem; }
    .hero-mid    { padding: 1.25rem 0; }
    .aside-cols  { grid-template-columns: 1fr; gap: 1rem; }
    .hero-bottom { flex-direction: column; align-items: flex-start; gap: 1.25rem; }
    .hero-cta    { width: 100%; text-align: center; }
    .loading-phrase { font-size: 0.75rem; width: calc(100vw / 3); }
  }
</style>
