---
const proof = [
  { lead: "Fixed pricing",       rest: "the number I quote is the number you pay" },
  { lead: "Fast, modern builds", rest: "they load before your customer loses patience" },
  { lead: "Full handover docs",  rest: "every login, every password — all yours" },
  { lead: "A real person",       rest: "on the other end of a real WhatsApp number" },
];
---

<section class="hero">
  <div class="cloud-grid">
    <div class="cloud-blocks">
      <div class="cloud-block block-1"><img src="/images/cloudsbg.jpg" alt="clouds" /></div>
      <div class="cloud-block block-2"><img src="/images/cloudsbg.jpg" alt="clouds" /></div>
      <div class="cloud-block block-3"><img src="/images/cloudsbg.jpg" alt="clouds" /></div>
    </div>

    <div class="hero-text">
      <p class="hero-tagline">Durban Web Design</p>
      <h1>A Website You Own.<br/>Built by Someone You<br/>Can Actually Reach.</h1>
      <p class="hero-sub">For small businesses and creators tired of being invisible online — and tired of agencies who treat them like a ticket number. Clean builds, fixed pricing, no nonsense.</p>
      <a href="#contact" class="hero-cta">Let's Build This →</a>
      <p class="hero-secondary">Based in Phoenix, Durban. Building for businesses across South Africa.</p>
    </div>
  </div>
</section>

<!-- Social proof bar -->
<div class="social-proof">
  <div class="proof-inner">
    {proof.map((item) => (
      <div class="proof-item">
        <span class="proof-check">✓</span>
        <p><strong>{item.lead}</strong> — {item.rest}</p>
      </div>
    ))}
  </div>
</div>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    background: linear-gradient(180deg,
      #4e6b7c 0%,
      #3a5060 28%,
      #2e2535 55%,
      #1f1618 78%,
      #1a1210 100%
    );
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  /* ── Cloud grid ── */
  .cloud-grid {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: visible;
  }

  .cloud-blocks {
    position: absolute;
    display: flex;
    width: 1350px;
    justify-content: center;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .cloud-block { flex-shrink: 0; overflow: hidden; width: 450px; }

  .block-1 { height: 580px; position: relative; top: 150px; }
  .block-2 { height: 580px; position: relative; top: 0; }
  .block-3 { height: 580px; position: relative; top: -90px; }

  .cloud-block img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    transform: rotate(90deg) scale(2);
  }

  .block-2 img { transform: rotate(90deg) scale(2) scaleY(-1); }

  /* ── Hero text ── */
  .hero-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 5;
    background: rgba(26, 18, 16, 0.72);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border: 1px solid rgba(210, 153, 146, 0.16);
    border-top: 1px solid rgba(210, 153, 146, 0.4);
    padding: 2.75rem 4rem;
    width: 640px;
    max-width: 90vw;
  }

  .hero-tagline {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #e0aaa3;
    opacity: 0.9;
    margin-bottom: 0.85rem;
    font-family: 'Inter', sans-serif;
  }

  .hero-text h1 {
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    font-weight: 400;
    line-height: 1.1;
    color: #f0ece4;
    margin-bottom: 1.1rem;
    letter-spacing: -0.01em;
  }

  .hero-sub {
    font-size: 0.95rem;
    opacity: 0.72;
    line-height: 1.7;
    margin-bottom: 1.75rem;
    color: #f0ece4;
    font-weight: 300;
    max-width: 30rem;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-cta {
    display: inline-block;
    background: #D29992;
    color: #1a1210;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.8rem 2rem;
    transition: background 0.2s, transform 0.2s;
  }

  .hero-cta:hover { background: #e0aaa3; transform: translateY(-1px); }

  .hero-secondary {
    margin-top: 1.5rem;
    font-size: 0.72rem;
    color: rgba(240, 236, 228, 0.45);
    letter-spacing: 0.04em;
  }

  /* ── Social proof bar ── */
  .social-proof {
    background: #1a1210;
    border-bottom: 1px solid rgba(240, 236, 228, 0.07);
    padding: 1.5rem 2rem;
  }

  .proof-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .proof-item { display: flex; align-items: flex-start; gap: 0.6rem; }

  .proof-check { color: #D29992; font-size: 0.8rem; flex-shrink: 0; margin-top: 0.1rem; }

  .proof-item p { font-size: 0.78rem; line-height: 1.5; color: rgba(240, 236, 228, 0.55); }
  .proof-item strong { color: #f0ece4; font-weight: 600; }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .proof-inner { grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
  }

  @media (max-width: 768px) {
    .block-1, .block-3 { display: none; }

    .cloud-blocks {
      width: 100%;
      transform: translate(-50%, -50%);
      justify-content: center;
    }

    .cloud-block.block-2 { width: 90vw; height: 800px; margin-top: 0; }
    .cloud-block.block-2 img { object-fit: contain; width: 100%; height: 100%; }

    .hero-text { width: 86vw; padding: 1.75rem 1.5rem; }
    .hero-text h1 { font-size: 1.7rem; }
    .hero-sub { font-size: 0.85rem; }
  }

  @media (max-width: 560px) {
    .proof-inner { grid-template-columns: 1fr; gap: 1rem; }
  }
</style>
