---
const { home = false } = Astro.props;
const p = home ? "" : "/";
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <a class="footer-logo" href="/" aria-label="DamienBuilds home"><img src="/favicon.png" alt="DamienBuilds" /></a>
      <div>
        <p class="footer-name">DamienBuilds.dev</p>
        <p class="footer-tagline">Durban Web Design</p>
      </div>
    </div>
    <p class="footer-copy">Helping South African businesses get found — and stay owned.<br/>© 2026 DamienBuilds.dev</p>
    <div class="footer-right">
      <nav class="footer-links">
        <a href={`${p}#services`}>Services</a>
        <a href={`${p}#work`}>Work</a>
        <a href={`${p}#process`}>Process</a>
        <a href={`${p}#pricing`}>Pricing</a>
        <a href="/faq">FAQ</a>
        <a href={`${p}#contact`}>Contact</a>
      </nav>
      <p class="footer-legal">Built with Astro · Hosted on Netlify</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #120d0b;
    padding: 2.5rem 2rem;
    border-top: 1px solid rgba(240, 236, 228, 0.07);
  }

  .footer-inner {
    max-width: 1080px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .footer-brand { display: flex; align-items: center; gap: 0.85rem; }
  .footer-logo { width: 2.75rem; height: 2.75rem; flex-shrink: 0; display: block; }
  .footer-logo img { width: 100%; height: 100%; object-fit: contain; display: block; }
  .footer-name { font-size: 0.82rem; font-weight: 600; color: #f0ece4; letter-spacing: 0.04em; }
  .footer-tagline {
    font-size: 0.72rem;
    color: rgba(240, 236, 228, 0.35);
    margin-top: 0.1rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .footer-copy {
    font-size: 0.78rem;
    color: rgba(240, 236, 228, 0.35);
    line-height: 1.7;
    text-align: center;
  }

  .footer-right { display: flex; flex-direction: column; align-items: flex-end; gap: 0.6rem; }
  .footer-links { display: flex; gap: 1.25rem; flex-wrap: wrap; justify-content: flex-end; }

  .footer-links a {
    font-size: 0.8rem;
    color: rgba(240, 236, 228, 0.5);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: #D29992; }

  .footer-legal { font-size: 0.7rem; color: rgba(240, 236, 228, 0.25); letter-spacing: 0.04em; }

  @media (max-width: 600px) {
    .footer-inner { flex-direction: column; align-items: center; text-align: center; }
    .footer-right { align-items: center; }
    .footer-links { justify-content: center; }
  }
</style>
