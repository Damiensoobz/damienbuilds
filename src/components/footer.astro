---
const { home = false } = Astro.props;
const p = home ? "" : "/";
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <div>
        <a class="footer-logo" href="/" aria-label="DamienBuilds home">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 220 102" fill="none" aria-hidden="true">
            <text y="43" x="1" font-family="DM Sans, sans-serif" font-size="44" letter-spacing="-1.8"><tspan font-weight="300" fill="#ffffff">d</tspan><tspan font-weight="700" fill="#ffffff">b</tspan></text>
            <rect x="1" y="48" width="52" height="3.5" rx="1.5" fill="#E96530"/>
            <text x="1" y="88" font-family="DM Sans, sans-serif" font-size="28" letter-spacing="-0.8"><tspan font-weight="300" fill="#ffffff">damien</tspan><tspan font-weight="700" fill="#ffffff">builds</tspan><tspan font-weight="500" fill="#E96530" font-size="12" dy="-2">.dev</tspan></text>
          </svg>
        </a>
        <p class="footer-tagline">Durban Web Design</p>
      </div>
    </div>
    <p class="footer-copy">Helping South African businesses get found — and stay owned.<br/>© 2026 DamienBuilds.dev</p>
    <div class="footer-right">
      <nav class="footer-links">
        <a href={`${p}#services`}>Services</a>
        <a href={`${p}#work`}>Work</a>
        <a href={`${p}#process`}>Process</a>
        <a href="/pricing">Pricing</a>
        <a href="/faq">FAQ</a>
        <a href={`${p}#contact`}>Contact</a>
      </nav>
      <nav class="footer-legal-links">
        <a href="/privacy">Privacy Policy</a>
        <span aria-hidden="true">·</span>
        <a href="/terms">Terms of Use</a>
      </nav>
      <p class="footer-legal">Built with Astro · Hosted on Vercel</p>
    </div>
  </div>

  <div class="footer-badges">
    <span class="footer-badge">
      <svg viewBox="0 0 27 18" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect width="27" height="18" fill="#E03C31"/>
        <rect y="9" width="27" height="9" fill="#001489"/>
        <path d="M0 0 13.5 9 0 18" fill="none" stroke="#ffffff" stroke-width="7"/>
        <path d="M13.5 9H27" stroke="#ffffff" stroke-width="7"/>
        <path d="M0 0 13.5 9 0 18" fill="none" stroke="#007749" stroke-width="4.6"/>
        <path d="M13.5 9H27" stroke="#007749" stroke-width="4.6"/>
        <path d="M0 2.6 10 9 0 15.4Z" fill="#FFB81C"/>
        <path d="M0 4.8 6.7 9 0 13.2Z" fill="#000000"/>
      </svg>
      Proudly South African
    </span>
    <span class="footer-badge">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="#4FC3F7" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
        <circle cx="12" cy="12" r="9"/>
        <ellipse cx="12" cy="12" rx="4" ry="9"/>
        <path d="M3 12h18"/>
      </svg>
      Proudly human — made on Earth
    </span>
  </div>
</footer>

<style>
  .footer {
    background:
      radial-gradient(ellipse 100% 80% at 50% 100%, rgba(233, 101, 48, 0.04) 0%, transparent 100%),
      #0c1525;
    padding: 2.5rem 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer-inner {
    max-width: 1080px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .footer-brand { display: flex; align-items: flex-start; }
  .footer-logo { display: block; margin-bottom: 0.5rem; }
  .footer-logo svg { height: 3rem; width: auto; display: block; }
  .footer-tagline {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.35);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .footer-copy {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.35);
    line-height: 1.7;
    text-align: center;
  }

  .footer-right { display: flex; flex-direction: column; align-items: flex-end; gap: 0.6rem; }
  .footer-links { display: flex; gap: 1.25rem; flex-wrap: wrap; justify-content: flex-end; }

  .footer-links a {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: #E96530; }

  .footer-legal { font-size: 0.7rem; color: rgba(255, 255, 255, 0.25); letter-spacing: 0.04em; }

  .footer-legal-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
  }

  .footer-legal-links a {
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-legal-links a:hover { color: #E96530; }
  .footer-legal-links span { color: rgba(255, 255, 255, 0.2); }

  /* ── Badges row ── */
  .footer-badges {
    max-width: 1080px;
    margin: 1.75rem auto 0;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  .footer-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.45);
    white-space: nowrap;
  }

  .footer-badge svg {
    width: 18px;
    height: auto;
    display: block;
    flex-shrink: 0;
  }

  @media (max-width: 600px) {
    .footer-inner { flex-direction: column; align-items: center; text-align: center; }
    .footer-right { align-items: center; }
    .footer-links { justify-content: center; }
  }

  @media (max-width: 430px) {
    .footer        { padding: 2rem 1rem; }
    .footer-links  { gap: 0.85rem; }
    .footer-links a { font-size: 0.75rem; }
    .footer-badges { gap: 0.85rem 1.75rem; }
  }
</style>
