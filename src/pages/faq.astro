---
import BaseLayout from '../layouts/baseLayout.astro';
import SiteNav from '../components/siteNav.astro';
import Footer from '../components/footer.astro';

const topQuestions = [
  {
    q: "Do I actually own my website, or are you holding the keys?",
    a: `You own all of it — domain, hosting account, the lot. This is the part most "web guys" quietly skip so you're forced to keep paying them. I hand over everything in writing. If you walked away and never spoke to me again, you'd lose nothing.`,
  },
  {
    q: "How does payment work?",
    a: `50% deposit to lock in your spot and start the work, 50% on completion before the site goes live. Clear and simple — no drip-fed invoices, no surprise line items later.`,
  },
  {
    q: "How long will my website take?",
    a: `A standard 5-page build is usually 2–3 weeks. The single biggest factor is how quickly you get me your content — logo, photos, and any text you want included. If everything's ready on day one, it's faster. If I'm waiting two weeks for your logo, well… you do the math.`,
  },
  {
    q: "What's the difference between you and the guy charging R1,500?",
    a: `Sometimes nothing — if all you need is a one-page placeholder, the R1,500 guy might be the right call, and I'll say so. The difference shows up in what happens after. Cheap builds often skip proper hosting setup, hand you nothing, leave the SEO basics undone, and vanish when something breaks. I set the whole thing up properly, document it, and hand it over so you're never stranded. You're paying for the parts you can't see — the parts that matter when something goes wrong at 11pm.`,
  },
  {
    q: "What's the difference between a domain, hosting, and email? Do I need all three?",
    a: `Think of it like a shop. The <strong>domain</strong> is your street address (yourbusiness.co.za) — it's how people find you. <strong>Hosting</strong> is the actual shop space where your website lives. <strong>Email</strong> is your business phone line — you@yourbusiness.co.za instead of a personal Gmail. You need the domain and hosting to have a website at all. Business email is optional, but it makes you look established instead of like a side hustle run from a Hotmail account.`,
  },
];

const howItWorks = [
  {
    q: "How does the process work, start to finish?",
    a: `Six steps: a quick discovery chat, you send me your content, I design and build, we do two rounds of revisions, I launch it, and I hand everything over with full documentation. Most standard builds take 2–3 weeks depending on how fast content comes back to me. The full breakdown is on the <a href="/#process">Process</a> section of the home page.`,
  },
  {
    q: "What do you need from me to get started?",
    a: `Your logo (if you have one), any photos you want used, and a rough idea of what each page should say. Don't stress if it's messy or incomplete — shaping that into something usable is part of the job. If you've got nothing, we'll work it out together in the discovery chat.`,
  },
  {
    q: "What payment methods do you accept?",
    a: `EFT for now, with a secure card payment link available on request. Either way you'll get a proper invoice for your records.`,
  },
  {
    q: "What happens after my site goes live?",
    a: `You get a handover document with every login, password, and renewal date. The site is yours — fully. If you ever want changes down the line, you can do them yourself, hire anyone you like, or come back to me. No lock-in, no monthly fee unless you specifically want ongoing support.`,
  },
  {
    q: "What if I need changes after the build?",
    a: `Small tweaks during the project are covered by your two revision rounds. After launch, you can handle changes yourself (I'll show you how for the simple stuff), or send them my way for a small fee. No retainer required.`,
  },
  {
    q: "Can you redo or fix my existing website?",
    a: `Often, yes — depends on what it's built on and what state it's in. Send me the link and I'll tell you honestly whether a fix makes sense or whether you're better off with a fresh build.`,
  },
];

const whatYouPayFor = [
  {
    q: "Why can't I just use a Facebook page or Wix?",
    a: `You can — and for some businesses that's genuinely enough. But a Facebook page isn't yours; Meta can change the rules or shut it overnight, and you don't show up properly on Google. Wix gets you online but locks you into their platform and monthly fees, and the free version slaps their branding on your site. A proper website is an asset you own and control. The question is whether your business is at the point where that ownership matters yet — and I'll tell you straight if I don't think it is.`,
  },
  {
    q: "What does SEO actually do for me?",
    a: `SEO (search engine optimisation) is what decides whether you show up when someone Googles "plumber near me" or "best coffee Morningside." The basics I include — proper page titles, descriptions, a Google Business Profile, and a sitemap — get you eligible to be found. It's not magic and it's not instant; ranking takes time and consistency. But skipping it entirely is like opening a shop with no sign and the lights off.`,
  },
  {
    q: "Why does a professional email address matter?",
    a: `Because durbansalon22@gmail.com quietly tells a customer you're not fully serious, even if you are. you@yourbusiness.co.za costs a small monthly amount and does a surprising amount of heavy lifting for trust — especially when you're quoting against bigger competitors.`,
  },
  {
    q: `What does "mobile responsive" mean and why should I care?`,
    a: `It means your site looks right whether someone opens it on a laptop, a tablet, or their phone. Most of your customers will visit on a phone — if your site only looks good on a desktop, you're losing the majority before they've read a word. Every build I do is mobile-first by default.`,
  },
  {
    q: "Why do I need analytics? I just want a website.",
    a: `Because "I just want a website" usually becomes "is this website actually doing anything?" within a month. Google Analytics shows you how many people visit, where they come from, and which pages they leave on. It turns your site from a guess into something you can actually improve. It's optional — but flying blind is a choice.`,
  },
  {
    q: "What if I want to leave you later?",
    a: `Then you leave, and you take everything with you. That's the whole point of how I hand things over — every login and password is yours, documented. No hostage situations, no "you'll need to call me to move it." A website you can't leave isn't really yours.`,
  },
];
---

<BaseLayout title="FAQ — DamienBuilds | Durban Web Design">
  <SiteNav active="FAQ" />

  <!-- Header -->
  <header class="faq-hero">
    <div class="faq-hero-inner">
      <p class="faq-eyebrow">FAQ</p>
      <h1>Questions? Good.<br/>Here are the answers.</h1>
      <p class="faq-sub">No jargon, no sales fog. If something's not covered here, <a href="https://wa.me/27000000000" target="_blank" rel="noopener noreferrer">WhatsApp me</a> and I'll add it.</p>
    </div>
  </header>

  <main class="faq-main">

    <!-- Top Questions (always open) -->
    <section class="faq-section">
      <div class="section-head">
        <span class="section-tag">Start Here</span>
        <h2>The questions everyone asks first</h2>
      </div>
      <div class="top-list">
        {topQuestions.map((item) => (
          <article class="top-card">
            <h3>{item.q}</h3>
            <p set:html={item.a}></p>
          </article>
        ))}
      </div>
    </section>

    <!-- How This Actually Works -->
    <section class="faq-section">
      <div class="section-head">
        <span class="section-tag">01</span>
        <h2>How this actually works</h2>
      </div>
      <div class="accordion">
        {howItWorks.map((item) => (
          <details class="qa">
            <summary>
              <span class="q-text">{item.q}</span>
              <span class="q-icon" aria-hidden="true"></span>
            </summary>
            <div class="a-body"><p set:html={item.a}></p></div>
          </details>
        ))}
      </div>
    </section>

    <!-- What You're Actually Paying For -->
    <section class="faq-section">
      <div class="section-head">
        <span class="section-tag">02</span>
        <h2>What you're actually paying for</h2>
      </div>
      <div class="accordion">
        {whatYouPayFor.map((item) => (
          <details class="qa">
            <summary>
              <span class="q-text">{item.q}</span>
              <span class="q-icon" aria-hidden="true"></span>
            </summary>
            <div class="a-body"><p set:html={item.a}></p></div>
          </details>
        ))}
      </div>
    </section>

  </main>

  <!-- Closing CTA -->
  <section class="faq-cta">
    <div class="cta-inner">
      <h2>Still got questions?</h2>
      <p>That's normal — this stuff isn't your day job, it's mine. Send me a message and I'll give you a straight answer, no obligation.</p>
      <div class="cta-buttons">
        <a href="https://wa.me/27000000000" target="_blank" rel="noopener noreferrer" class="cta-primary">WhatsApp Me →</a>
        <a href="/#contact" class="cta-secondary">Get In Touch →</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* ── Header ── */
  .faq-hero {
    background: linear-gradient(180deg, #0f1a2e 0%, #090e1a 60%, #0d1117 100%);
    padding: 9rem 2rem 4rem;
  }

  .faq-hero-inner { max-width: 820px; margin: 0 auto; }

  .faq-eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #FF8C5A;
    margin-bottom: 1rem;
  }

  .faq-hero h1 {
    font-size: clamp(2.4rem, 5.5vw, 4rem);
    font-weight: 400;
    color: #e8edf8;
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
  }

  .faq-sub {
    font-size: 1rem;
    color: rgba(232, 237, 248, 0.6);
    line-height: 1.7;
    max-width: 34rem;
  }

  .faq-sub a {
    color: #FF6B35;
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 107, 53, 0.4);
  }

  .faq-sub a:hover { border-color: #FF6B35; }

  /* ── Main ── */
  .faq-main {
    background: #0d1117;
    padding: 4rem 2rem 5rem;
  }

  .faq-section {
    max-width: 820px;
    margin: 0 auto 4.5rem;
  }

  .faq-section:last-child { margin-bottom: 0; }

  .section-head {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(232, 237, 248, 0.1);
  }

  .section-tag {
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #FF6B35;
    flex-shrink: 0;
    font-family: 'Inter', sans-serif;
  }

  .section-head h2 {
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    font-weight: 400;
    color: #e8edf8;
    letter-spacing: -0.01em;
    line-height: 1.15;
  }

  /* ── Top cards (always open) ── */
  .top-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .top-card {
    background: #161d2f;
    border: 1px solid rgba(255, 107, 53, 0.18);
    border-left: 2px solid #FF6B35;
    padding: 1.75rem 2rem;
  }

  .top-card h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem;
    font-weight: 500;
    color: #e8edf8;
    line-height: 1.25;
    margin-bottom: 0.75rem;
  }

  .top-card p {
    font-size: 0.9rem;
    color: rgba(232, 237, 248, 0.65);
    line-height: 1.8;
  }

  .top-card :global(strong) { color: #FF8C5A; font-weight: 600; }

  /* ── Accordion ── */
  .accordion {
    display: flex;
    flex-direction: column;
  }

  .qa {
    border-bottom: 1px solid rgba(232, 237, 248, 0.1);
  }

  .qa summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.4rem 0.25rem;
    transition: color 0.2s;
  }

  .qa summary::-webkit-details-marker { display: none; }

  .q-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem;
    font-weight: 500;
    color: #e8edf8;
    line-height: 1.3;
    transition: color 0.2s;
  }

  .qa summary:hover .q-text { color: #FF8C5A; }

  /* Chevron */
  .q-icon {
    position: relative;
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    margin-top: 0.2rem;
  }

  .q-icon::before,
  .q-icon::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 9px;
    height: 1.5px;
    background: #FF6B35;
    transition: transform 0.3s ease;
  }

  .q-icon::before { left: 0; transform: rotate(45deg); }
  .q-icon::after  { right: 0; transform: rotate(-45deg); }

  .qa[open] .q-icon::before { transform: rotate(-45deg); }
  .qa[open] .q-icon::after  { transform: rotate(45deg); }

  .a-body {
    overflow: hidden;
    padding: 0 0 1.5rem;
    max-width: 92%;
  }

  .a-body p {
    font-size: 0.9rem;
    color: rgba(232, 237, 248, 0.62);
    line-height: 1.85;
  }

  .a-body :global(strong) { color: #FF8C5A; font-weight: 600; }

  .a-body :global(a) {
    color: #FF6B35;
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 107, 53, 0.4);
  }

  .a-body :global(a):hover { border-color: #FF6B35; }

  /* Open animation */
  .qa[open] .a-body { animation: faqReveal 0.3s ease; }

  @keyframes faqReveal {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Closing CTA ── */
  .faq-cta {
    background: #161d2f;
    border-top: 1px solid rgba(255, 107, 53, 0.15);
    padding: 5rem 2rem;
  }

  .cta-inner {
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
  }

  .cta-inner h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    color: #e8edf8;
    letter-spacing: -0.01em;
    margin-bottom: 1rem;
  }

  .cta-inner p {
    font-size: 0.95rem;
    color: rgba(232, 237, 248, 0.6);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-primary,
  .cta-secondary {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.9rem 2rem;
    transition: all 0.2s;
  }

  .cta-primary {
    background: #FF6B35;
    color: #0d1117;
  }

  .cta-primary:hover { background: #FF8C5A; transform: translateY(-1px); }

  .cta-secondary {
    background: transparent;
    color: #e8edf8;
    border: 1px solid rgba(232, 237, 248, 0.25);
  }

  .cta-secondary:hover { border-color: #FF6B35; color: #FF6B35; }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .faq-hero { padding: 7rem 1.25rem 3rem; }
    .faq-main { padding: 3rem 1.25rem 4rem; }
    .top-card { padding: 1.5rem 1.4rem; }
    .a-body { max-width: 100%; }
    .q-text { font-size: 1.15rem; }
    .cta-buttons { flex-direction: column; }
    .cta-primary, .cta-secondary { text-align: center; }
  }
</style>
