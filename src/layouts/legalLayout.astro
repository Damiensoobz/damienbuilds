---
import BaseLayout from './baseLayout.astro';
import SiteNav from '../components/siteNav.astro';
import Footer from '../components/footer.astro';

const { title, description, heading, eyebrow = "Legal", updated } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <SiteNav />

  <header class="legal-hero">
    <div class="legal-hero-inner">
      <p class="legal-eyebrow">{eyebrow}</p>
      <h1>{heading}</h1>
      {updated && <p class="legal-updated">Last updated: {updated}</p>}
    </div>
  </header>

  <main class="legal-main">
    <article class="legal-body">
      <slot />
    </article>
  </main>

  <Footer />
</BaseLayout>

<style>
  .legal-hero {
    position: relative;
    background:
      radial-gradient(ellipse 70% 50% at 20% 40%, rgba(79, 195, 247, 0.08) 0%, transparent 100%),
      radial-gradient(ellipse 50% 40% at 80% 80%, rgba(233, 101, 48, 0.06) 0%, transparent 100%),
      linear-gradient(180deg, #0f1a2e 0%, #090e1a 60%, #0c1525 100%);
    padding: 9rem 2rem 3.5rem;
  }

  .legal-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255, 255, 255, 0.07) 1px, transparent 1px);
    background-size: 28px 28px;
    z-index: 0;
    pointer-events: none;
  }

  .legal-hero-inner { position: relative; z-index: 1; max-width: 760px; margin: 0 auto; }

  .legal-eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #4FC3F7;
    margin-bottom: 1rem;
  }

  .legal-hero h1 {
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    font-weight: 400;
    color: #ffffff;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .legal-updated {
    margin-top: 1rem;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.4);
    letter-spacing: 0.02em;
  }

  .legal-main {
    background: #0c1525;
    padding: 3.5rem 2rem 5rem;
  }

  .legal-body {
    max-width: 760px;
    margin: 0 auto;
    color: rgba(255, 255, 255, 0.7);
  }

  /* ── Prose styling (applies to slotted content) ── */
  .legal-body :global(h2) {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem;
    font-weight: 500;
    color: #ffffff;
    letter-spacing: -0.01em;
    margin: 2.75rem 0 1rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .legal-body :global(h2:first-child) { margin-top: 0; }

  .legal-body :global(h3) {
    font-size: 1rem;
    font-weight: 600;
    color: #ffffff;
    margin: 1.75rem 0 0.6rem;
  }

  .legal-body :global(p) {
    font-size: 0.92rem;
    line-height: 1.85;
    margin-bottom: 1.1rem;
  }

  .legal-body :global(ul) {
    margin: 0 0 1.1rem;
    padding-left: 0;
    list-style: none;
  }

  .legal-body :global(li) {
    font-size: 0.92rem;
    line-height: 1.8;
    padding-left: 1.5rem;
    position: relative;
    margin-bottom: 0.6rem;
  }

  .legal-body :global(li)::before {
    content: '›';
    position: absolute;
    left: 0.25rem;
    color: #E96530;
    font-weight: 700;
  }

  .legal-body :global(strong) { color: #ffffff; font-weight: 600; }

  .legal-body :global(a) {
    color: #E96530;
    text-decoration: none;
    border-bottom: 1px solid rgba(233, 101, 48, 0.4);
  }

  .legal-body :global(a:hover) { border-color: #E96530; }

  /* Highlighted inserts that Damien still needs to fill in */
  .legal-body :global(.insert) {
    color: #FFB81C;
    font-weight: 600;
    background: rgba(255, 184, 28, 0.08);
    padding: 0.05rem 0.35rem;
    border-radius: 2px;
  }

  .legal-body :global(.note) {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.45);
    border-left: 2px solid rgba(79, 195, 247, 0.4);
    padding: 0.25rem 0 0.25rem 1rem;
    margin: 1.5rem 0;
    line-height: 1.7;
  }

  @media (max-width: 600px) {
    .legal-hero { padding: 7rem 1.25rem 3rem; }
    .legal-main { padding: 2.5rem 1.25rem 4rem; }
  }
</style>
