---
const { title = "DamienBuilds | Durban Web Design for Small Businesses & Creators" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Durban-based web designer building clean, fast websites for small businesses and creators. Fixed pricing, no agency runaround, and you own everything when we're done." />
    <title>{title}</title>

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
      :root {
        --bg-1:      #0d1117;   /* darkest — process, contact, hero      */
        --bg-2:      #0f1520;   /* services                              */
        --bg-3:      #161d2f;   /* work / cards — raised surface         */
        --accent:    #FF6B35;   /* electric orange                       */
        --accent-hi: #FF8C5A;   /* hover                                 */
        --ink:       #e8edf8;
        --ink-2:     rgba(232,237,248,0.62);
        --ink-3:     rgba(232,237,248,0.38);
        --line:      rgba(255,255,255,0.08);
        --line-warm: rgba(255,107,53,0.2);
      }

      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: 'Inter', sans-serif;
        background-color: #0d1117;
        color: #e8edf8;
        font-size: 16px;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      h1, h2, h3, h4 {
        font-family: 'Cormorant Garamond', serif;
        font-weight: 400;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
